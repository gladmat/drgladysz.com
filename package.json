{
  "name": "drgladysz",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Personal brand and content platform for Mateusz Gładysz, MD, FEBOPRAS, FEBHS — Consultant Plastic and Hand Surgeon. Astro + Sanity + Vercel.",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "type-check": "astro check && tsc --noEmit",
    "codegen:schema": "sanity schema extract --workspace=default --enforce-required-fields",
    "codegen:types": "sanity typegen generate",
    "codegen": "npm run codegen:schema && npm run codegen:types",
    "studio:dev": "sanity dev",
    "studio:build": "sanity build",
    "studio:deploy": "sanity deploy"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.0",
    "@astrojs/preact": "^5.0.0",
    "@astrojs/sitemap": "^3.7.0",
    "@astrojs/vercel": "^10.0.6",
    "@citation-js/plugin-bibtex": "^0.7.16",
    "@citation-js/plugin-csl": "^0.7.16",
    "@sanity/client": "^7.0.0",
    "@sanity/image-url": "^2.1.1",
    "@sanity/vision": "^5.21.0",
    "@tailwindcss/vite": "^4.0.0",
    "astro": "^6.0.0",
    "citation-js": "^0.7.16",
    "preact": "^10.24.0",
    "react": "^19.2.2",
    "react-dom": "^19.2.2",
    "resend": "^6.12.2",
    "sanity": "^5.21.0",
    "styled-components": "^6.4.1",
    "tailwindcss": "^4.0.0"
