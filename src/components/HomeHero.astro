---
// HomeHero — master-wordmark hero for the Home page.
//
// Composition (per _handoff/content/home-en.md §1, v1.6.2):
//   - credentials line (Plex Mono, accent, uppercase, tracked)
//   - display name on two lines, master wordmark Plex Serif Medium 500,
//     clamp(48px, 7.5vw, 96px), line-height 1.0, letter-spacing -0.02em,
//     lowercase + cap M / cap G, both names upright (never italic)
//   - italic positioning sentence (Plex Serif Italic, ink-2, max 28ch)
//   - solid CTA button → /en/contact
//   - 4:5 portrait of img-12 in the right column (LCP image)
//
// Per brand spec v1.8 §2: "Where the master Medium 500 wordmark applies.
// Hero blocks on web pages." The cover-spread Regular 400 variant is
// reserved for brand-book covers, document title pages, slide title slides
// only — v1.6 mockups used Regular 400 in error; v1.6.2 corrects this.
//
// The image is the LCP. To match BaseLayout's <link rel="preload"> exactly,
// the <Picture> options here MUST stay aligned with what the page passes to
// `heroPreload` (same widths, sizes, quality, format set). Constants live in
// src/lib/image-config.ts.
import { Picture } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import {
  IMAGE_WIDTHS,
  IMAGE_QUALITY,
  IMAGE_SIZES_HERO_SPLIT,
  IMAGE_FORMATS,
} from '@/lib/image-config';

interface Props {
  photo: ImageMetadata;
  photoAlt: string;
  ctaHref?: string;
  ctaLabel?: string;
}

const {
  photo,
  photoAlt,
  ctaHref = '/en/contact',
  ctaLabel = 'Make an appointment',
} = Astro.props;
---
<section class="home-hero">
  <div class="hero-inner">
    <div class="hero-grid">
      <div class="hero-text">
        <p class="hero-credentials">
          MD&nbsp;·&nbsp;FEBOPRAS&nbsp;·&nbsp;FEBHS
        </p>
        <h1 class="hero-name">
          <span class="cap">M</span>ateusz <span class="second"><span class="cap">G</span>ładysz</span>
        </h1>
        {Astro.slots.has('qualifications') && (
          <div class="hero-qualifications">
            <slot name="qualifications" />
          </div>
        )}
        <p class="hero-positioning">
          Surgical care for the hand and reconstructive microsurgery — European double board-certified plastic and hand surgeon, with clinical practice across Switzerland, Germany, Australia, and New Zealand.
        </p>
        <a href={ctaHref} class="hero-cta">
          <span>{ctaLabel}</span>
          <span class="arrow" aria-hidden="true">→</span>
        </a>
      </div>
      <div class="hero-image">
        <Picture
          src={photo}
          alt={photoAlt}
          formats={[...IMAGE_FORMATS]}
          widths={[...IMAGE_WIDTHS]}
          sizes={IMAGE_SIZES_HERO_SPLIT}
          quality={IMAGE_QUALITY}
          loading="eager"
          decoding="async"
          fetchpriority="high"
          pictureAttributes={{ class: 'hero-picture' }}
        />
      </div>
    </div>
  </div>
</section>

<style>
  .home-hero {
    padding-block: clamp(60px, 9vh, 110px) clamp(80px, 12vh, 140px);
    background: var(--bg);
  }
  .hero-inner {
    max-width: 1320px;
    margin: 0 auto;
    padding-inline: clamp(20px, 5vw, 80px);
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 6fr 5fr;
    gap: clamp(40px, 6vw, 96px);
    align-items: center;
  }
  @media (max-width: 900px) {
    .hero-grid { grid-template-columns: 1fr; gap: 40px; }
  }

  .hero-credentials {
    font-family: var(--mono);
    font-weight: 400;
    font-size: 16px;
    letter-spacing: 0.14em;
    color: var(--accent);
    text-transform: uppercase;
    margin: 0 0 32px;
    max-width: none;
  }

  .hero-name {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(48px, 7.5vw, 96px);
    line-height: 1.0;
    letter-spacing: -0.02em;
    color: var(--ink);
    text-transform: lowercase;
    margin: 0 0 28px;
  }
  .hero-name .cap { text-transform: none; }
  .hero-name .second { display: block; }

  /* Qualifications slot — sits between wordmark and positioning sentence.
     The slot wrapper's margin replaces the wordmark's lower margin, keeping
     vertical rhythm tight so the hero text column stays well within the
     image column's height (image dominates the row, so nothing here adds
     to the hero's overall vertical footprint). */
  .hero-qualifications {
    margin: 0 0 28px;
  }

  .hero-positioning {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(18px, 1.7vw, 22px);
    line-height: 1.5;
    color: var(--ink-2);
    max-width: 28ch;
    margin: 0 0 40px;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-family: var(--sans);
    font-weight: 500;
    font-size: 15px;
    letter-spacing: 0.02em;
    color: var(--bg);
    background: var(--ink);
    padding: 14px 28px;
    border: 1px solid var(--ink);
    text-decoration: none;
    transition: background-color 0.2s, border-color 0.2s, color 0.2s;
  }
  .hero-cta:hover,
  .hero-cta:focus-visible {
    background: var(--accent);
    border-color: var(--accent);
    color: var(--bg);
  }
  .hero-cta .arrow { font-family: var(--mono); }

  .hero-image {
    aspect-ratio: 4 / 5;
    background-color: var(--bg-deep);
    overflow: hidden;
  }
  .hero-image :global(.hero-picture),
  .hero-image :global(.hero-picture img) {
    display: block;
    width: 100%;
    height: 100%;
  }
  .hero-image :global(.hero-picture img) {
    object-fit: cover;
    object-position: center 10%;
    filter: saturate(0.96);
  }
</style>
