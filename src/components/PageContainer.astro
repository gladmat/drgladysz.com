---
interface Props {
  as?: 'div' | 'section' | 'article' | 'header' | 'footer';
  class?: string;
}

const { as: Tag = 'div', class: className = '' } = Astro.props;
---
<Tag class:list={['page-container', className]}>
  <slot />
</Tag>

<style>
  .page-container {
    max-width: 1320px;
    margin: 0 auto;
    padding-inline: clamp(20px, 5vw, 80px);
  }
</style>
