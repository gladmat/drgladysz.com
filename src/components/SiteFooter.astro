---
interface Props {
  locale?: 'en' | 'pl';
}

const { locale = 'en' } = Astro.props;

// Footer copy and link order match the locked legal-pages-package
// `_meta/footer-config.json` exactly. The legal-link order is:
//   Imprint → Privacy Policy → Medical Disclaimer → Consent → Credentials.
// The disclaimer-band text and colophon are the locked copy from the same
// source. Brand spec §11.
const t = locale === 'pl'
  ? {
      identityHeading: 'Tożsamość',
      credentialsHeading: 'Uprawnienia',
      researchHeading: 'Badania',
      siteHeading: 'Witryna',
      consultLanguagesLabel: 'Języki konsultacji:',
      memberLabel: 'Członek:',
      legalLabel: 'Informacje prawne',
      // Locked: footer-config.json#pl.disclaimerBand
      disclaimer:
        'Informacje zawarte na niniejszej stronie mają charakter ogólny i edukacyjny. Nie stanowią porady lekarskiej i nie zastępują konsultacji z wykwalifikowanym specjalistą.',
      // Locked: footer-config.json#pl.typeAttribution
      colophon: 'Aarau Graphite · Krój IBM Plex',
      rights: 'Wszelkie prawa zastrzeżone.',
      navHome: 'Strona główna',
      navAbout: 'O mnie',
      navProcedures: 'Zabiegi',
      navPublications: 'Publikacje',
      navBlog: 'Baza wiedzy',
      navCalculators: 'Kalkulatory',
      navGlossary: 'Słowniczek',
      navLearn: 'Przygotowanie do FEBHS (po angielsku)',
      navContact: 'Kontakt',
      navCredentials: 'Uprawnienia',
      navImprint: 'Nota prawna',
      navPrivacy: 'Polityka prywatności',
      navDisclaimer: 'Zastrzeżenie medyczne',
      navConsent: 'Zgoda',
    }
  : {
      identityHeading: 'Identity',
      credentialsHeading: 'Credentials',
      researchHeading: 'Research',
      siteHeading: 'Site',
      consultLanguagesLabel: 'Consultation languages:',
      memberLabel: 'Member:',
      legalLabel: 'Legal',
      // Locked: footer-config.json#en.disclaimerBand
      disclaimer:
        'The information on this website is provided for general guidance and educational purposes. It does not constitute medical advice and does not replace consultation with a qualified medical practitioner.',
      // Locked: footer-config.json#en.typeAttribution
      colophon: 'Aarau Graphite · Set in IBM Plex',
      rights: 'All rights reserved.',
      navHome: 'Home',
      navAbout: 'About',
      navProcedures: 'Procedures',
      navPublications: 'Publications',
      navBlog: 'Knowledge base',
      navCalculators: 'Calculators',
      navGlossary: 'Glossary',
      navLearn: 'FEBHS prep',
      navContact: 'Contact',
      navCredentials: 'Credentials',
      navImprint: 'Imprint',
      navPrivacy: 'Privacy Policy',
      navDisclaimer: 'Medical Disclaimer',
      navConsent: 'Consent',
    };

const localePrefix = locale === 'pl' ? '/pl' : '/en';

// Footer "Site" column links. The FEBHS-prep entry points at the
// learn.drgladysz.com sub-application (separate Astro project per brand
// spec v1.8 Decision #29/30 — quiz/exam-prep platform lives on its own
// subdomain, not on the main domain). It's rendered with target="_blank"
// + rel="noopener noreferrer" so the browser handles the cross-subdomain hop, and
// `external: true` marks it for the small ↗ visual cue. The PL footer
// labels the link "(po angielsku)" because FESSH MCQ content is English-only.
const navLinks: { href: string; label: string; external?: boolean }[] =
  locale === 'pl'
    ? [
        { href: '/pl/', label: t.navHome },
        { href: '/pl/o-mnie/', label: t.navAbout },
        { href: '/pl/zabiegi/', label: t.navProcedures },
        { href: '/pl/publikacje/', label: t.navPublications },
        { href: '/pl/blog/', label: t.navBlog },
        { href: '/pl/kalkulatory/', label: t.navCalculators },
        { href: '/pl/slowniczek/', label: t.navGlossary },
        { href: 'https://learn.drgladysz.com', label: t.navLearn, external: true },
        { href: '/pl/kontakt/', label: t.navContact },
      ]
    : [
        { href: '/en/', label: t.navHome },
        { href: '/en/about/', label: t.navAbout },
        { href: '/en/procedures/', label: t.navProcedures },
        { href: '/en/publications/', label: t.navPublications },
        { href: '/en/blog/', label: t.navBlog },
        { href: '/en/calculators/', label: t.navCalculators },
        { href: '/en/glossary/', label: t.navGlossary },
        { href: 'https://learn.drgladysz.com', label: t.navLearn, external: true },
        { href: '/en/contact/', label: t.navContact },
      ];

// Locked link order from `01-brand-system/legal-pages-package/_meta/footer-config.json`:
// Imprint → Privacy → Disclaimer → Consent → Credentials. Credentials lives
// only here (legal column 4 per brand spec §11), not in `navLinks` above.
const legalLinks = locale === 'pl'
  ? [
      { href: '/pl/nota-prawna/', label: t.navImprint },
      { href: '/pl/polityka-prywatnosci/', label: t.navPrivacy },
      { href: '/pl/zastrzezenie-medyczne/', label: t.navDisclaimer },
      { href: '/pl/zgoda/', label: t.navConsent },
      { href: '/pl/uprawnienia/', label: t.navCredentials },
    ]
  : [
      { href: '/en/imprint/', label: t.navImprint },
      { href: '/en/privacy/', label: t.navPrivacy },
      { href: '/en/disclaimer/', label: t.navDisclaimer },
      { href: '/en/consent/', label: t.navConsent },
      { href: '/en/credentials/', label: t.navCredentials },
    ];

const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="footer-inner">
    <div class="signature">
      <span class="cap">M</span>ateusz <span class="cap">G</span>ładysz
    </div>

    <div class="columns">
      <div class="col">
        <h2>{t.identityHeading}</h2>
        <div class="col-content">
          <p>
            Mateusz Gładysz<br />
            MD, FEBOPRAS, FEBHS<br />
            {locale === 'pl'
              ? 'Konsultant chirurgii plastycznej i chirurgii ręki'
              : 'Consultant Plastic and Hand Surgeon'}
          </p>
          <p>
            <a href="mailto:office@drgladysz.com">office@drgladysz.com</a>
          </p>
          <p class="muted">
            {t.consultLanguagesLabel}<br />
            English, Polski, Deutsch
          </p>
        </div>
      </div>

      <div class="col">
        <h2>{t.credentialsHeading}</h2>
        <div class="col-content">
          <p>
            Medical Council of New Zealand<br />
            Registration 93463
          </p>
          <p>
            Fellow of the European Board of Plastic, Reconstructive and Aesthetic Surgery
          </p>
          <p>
            Fellow of the European Board of Hand Surgery
          </p>
          <p class="member-label"><em>{t.memberLabel}</em></p>
          <p>
            Polskie Towarzystwo Chirurgii Plastycznej, Rekonstrukcyjnej i&nbsp;Estetycznej
          </p>
          <p>Polskie Towarzystwo Chirurgii Ręki</p>
          <p>International Member, American Society for Surgery of the Hand</p>
        </div>
      </div>

      <div class="col">
        <h2>{t.researchHeading}</h2>
        <div class="col-content">
          <ul>
            <li>
              <span class="muted">ORCID:</span>{' '}
              <a href="https://orcid.org/0009-0009-2380-4056" rel="me noopener noreferrer" target="_blank">
                0009-0009-2380-4056
              </a>
            </li>
            <li>
              <span class="muted">LinkedIn:</span>{' '}
              <a href="https://www.linkedin.com/in/mateuszgladysz" rel="me noopener noreferrer" target="_blank">
                linkedin.com/in/mateuszgladysz
              </a>
            </li>
          </ul>
        </div>
      </div>

      <div class="col">
        <h2>{t.siteHeading}</h2>
        <div class="col-content">
          <ul>
            {navLinks.map((link) => (
              <li>
                {link.external ? (
                  <a href={link.href} target="_blank" rel="noopener noreferrer">
                    {link.label} <span aria-hidden="true" class="ext">↗</span>
                  </a>
                ) : (
                  <a href={link.href}>{link.label}</a>
                )}
              </li>
            ))}
          </ul>
          <ul class="legal-list">
            {legalLinks.map((link) => (
              <li><a href={link.href}>{link.label}</a></li>
            ))}
          </ul>
        </div>
      </div>
    </div>

    <p class="disclaimer">{t.disclaimer}</p>

    <div class="copyright">
      <span>© {year} Mateusz Gładysz. {t.rights}</span>
      <span>{t.colophon}</span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--bg-dark);
    color: var(--ink-on-dark);
    padding: clamp(60px, 10vh, 100px) 0 40px;
    margin-top: clamp(60px, 10vh, 120px);
  }
  .footer-inner {
    max-width: 1320px;
    margin: 0 auto;
    padding-inline: clamp(20px, 5vw, 80px);
  }
  /* Footer signature uses Plex Serif Regular 400 per v1.6.2 locked content
     (lighter than the master Medium 500 wordmark — distinctive footer
     register). Lowercase except M and G via .cap. Both names upright,
     never italic per Decision #5 in v1.8 spec. */
  .signature {
    font-family: var(--serif);
    font-weight: 400;
    font-size: clamp(28px, 3vw, 40px);
    line-height: 1.1;
    color: var(--ink-on-dark);
    letter-spacing: -0.02em;
    text-transform: lowercase;
    margin-bottom: 32px;
  }
  .signature .cap { text-transform: none; }

  .columns {
    display: grid;
    grid-template-columns: 1.2fr 1.5fr 1fr 0.8fr;
    gap: 40px;
    margin-bottom: 48px;
  }
  @media (max-width: 768px) {
    .columns { grid-template-columns: 1fr 1fr; gap: 32px; }
  }

  /* Footer column headings — semantically <h2> (top-level groupings of
     footer content, peers of any in-page <h2>) so they don't break the
     document outline by skipping levels. Visual register stays mono caps
     10px to match the existing brand treatment. */
  h2 {
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(250, 247, 242, 0.62);
    margin: 0 0 14px;
    font-weight: 500;
  }
  p {
    color: rgba(250, 247, 242, 0.85);
    font-size: 13px;
    line-height: 1.6;
    margin: 0 0 14px;
    max-width: none;
  }
  p.muted, .muted { color: rgba(250, 247, 242, 0.55); }
  .member-label { margin-top: 14px; margin-bottom: 6px; font-size: 12px; color: rgba(250, 247, 242, 0.6); }

  ul {
    list-style: none;
    padding: 0;
    margin: 0 0 14px;
  }
  li {
    color: rgba(250, 247, 242, 0.85);
    font-size: 13px;
    line-height: 1.7;
  }
  /* Mobile touch-target compliance: WCAG 2.5.8 requires ≥24px square.
     The default 13px font × 1.7 line-height gives 22.1px without
     padding — adding inline-block + padding-block lifts every list-link
     above the threshold without disturbing inline-link styling
     elsewhere in the footer (mailto, bracketed mono labels). */
  .col-content ul li a {
    display: inline-block;
    padding-block: 0.25rem;
  }
  .col-content ul li {
    margin-block: 0.05rem;
  }
  a {
    color: rgba(250, 247, 242, 0.85);
    text-decoration: none;
    border-bottom: 1px solid rgba(250, 247, 242, 0.25);
    padding-bottom: 1px;
    transition: color 0.2s, border-color 0.2s;
  }
  a:hover {
    color: var(--ink-on-dark);
    border-bottom-color: rgba(250, 247, 242, 0.6);
  }

  .legal-list { margin-top: 16px; }

  /* External-link arrow on the FEBHS-prep subdomain link. */
  .ext {
    display: inline-block;
    font-size: 0.85em;
    margin-left: 2px;
    color: rgba(250, 247, 242, 0.55);
  }

  .disclaimer {
    border-top: 1px solid rgba(250, 247, 242, 0.1);
    padding-top: 24px;
    font-size: 12px;
    line-height: 1.6;
    color: rgba(250, 247, 242, 0.6);
    margin-bottom: 24px;
    max-width: 80ch;
  }
  .copyright {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
    font-family: var(--mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(250, 247, 242, 0.5);
  }
</style>
