---
// src/components/content/PortableTextSpan.astro
//
// Renders a single Portable Text span with its marks. Decorators (em, strong,
// code, underline, strike-through) wrap the text from inside out; link
// annotations wrap the whole span; citation annotations APPEND a numbered
// superscript marker AFTER the span's text (does not wrap it); glossaryTerm
// annotations REPLACE the span's text with a <GlossaryTerm> trigger button.
//
// When a span has a glossaryTerm mark, decorator and link composition is
// skipped — the article body convention puts plain text inside `[gloss:slug|...]`
// markers, and a <button> trigger can't nest an <a> per HTML interactive-content
// rules. Decorators on the same span as a glossary mark are silently dropped.
//
// Citations follow the rendered span as Astro components, so they pull in
// their own scoped styles.
import Citation from '@/components/content/Citation.astro';
import GlossaryTerm from '@/components/content/GlossaryTerm.astro';
import type { SanityRefDoc, SanityGlossaryTerm } from '@/lib/sanity';

interface Span {
  _type: 'span';
  _key?: string;
  text: string;
  marks?: string[];
}

interface MarkDef {
  _type: string;
  _key: string;
  href?: string;
  newTab?: boolean;
  reference?: { _ref: string };
  term?: { _ref: string };
}

interface Props {
  span: Span;
  markDefs: MarkDef[];
  references: SanityRefDoc[];
  referenceIndex: Map<string, number>;
  glossaryTerms: SanityGlossaryTerm[];
}

const { span, markDefs, references, referenceIndex, glossaryTerms } =
  Astro.props;
const marks = span.marks ?? [];

const ESCAPE_MAP: Record<string, string> = {
  '&': '&amp;',
  '<': '&lt;',
  '>': '&gt;',
  '"': '&quot;',
  "'": '&#39;',
};
function esc(s: string): string {
  return s.replace(/[&<>"']/g, (c) => ESCAPE_MAP[c]);
}

// Split marks into decorators and annotation keys.
const annotationKeys: string[] = [];
const decorators: string[] = [];
for (const m of marks) {
  if (markDefs.some((d) => d._key === m)) {
    annotationKeys.push(m);
  } else {
    decorators.push(m);
  }
}

const linkAnnotation = annotationKeys
  .map((k) => markDefs.find((d) => d._key === k))
  .find((d): d is MarkDef => Boolean(d) && d!._type === 'link');

const citationAnnotations = annotationKeys
  .map((k) => markDefs.find((d) => d._key === k))
  .filter((d): d is MarkDef => Boolean(d) && d!._type === 'citation');

const glossaryAnnotation = annotationKeys
  .map((k) => markDefs.find((d) => d._key === k))
  .find((d): d is MarkDef => Boolean(d) && d!._type === 'glossaryTerm');

const citationData = citationAnnotations
  .map((annot) => {
    const refId = annot.reference?._ref;
    if (!refId) return null;
    const idx = referenceIndex.get(refId);
    const ref = references.find((r) => r._id === refId);
    if (!idx || !ref) return null;
    // markKey is unique per occurrence (Portable Text mark _key); index is
    // the bibliography number (same across re-citations). Citation needs
    // both — markKey for popover element ID uniqueness, index for display.
    return { ref, index: idx, markKey: annot._key };
  })
  .filter(
    (d): d is { ref: SanityRefDoc; index: number; markKey: string } =>
      d !== null,
  );

const glossaryData = glossaryAnnotation
  ? (() => {
      const termId = glossaryAnnotation.term?._ref;
      if (!termId) return null;
      const term = glossaryTerms.find((g) => g._id === termId);
      if (!term) return null;
      return { term, markKey: glossaryAnnotation._key };
    })()
  : null;

// Compose decorators from innermost outwards. Order matters cosmetically:
// strong wraps em wraps code wraps underline wraps strike-through wraps text.
let inner = esc(span.text);
if (decorators.includes('code')) inner = `<code>${inner}</code>`;
if (decorators.includes('underline')) {
  inner = `<span style="text-decoration: underline;">${inner}</span>`;
}
if (decorators.includes('strike-through')) inner = `<del>${inner}</del>`;
if (decorators.includes('em')) inner = `<em>${inner}</em>`;
if (decorators.includes('strong')) inner = `<strong>${inner}</strong>`;

// Wrap with link if present. Skipped when a glossary mark is present (a
// <button> can't nest inside an <a> per HTML interactive-content rules).
if (linkAnnotation && linkAnnotation.href && !glossaryData) {
  const targetAttr = linkAnnotation.newTab ? ' target="_blank" rel="noopener"' : '';
  inner = `<a href="${esc(linkAnnotation.href)}"${targetAttr}>${inner}</a>`;
}
---
{glossaryData ? (
  <GlossaryTerm
    term={glossaryData.term}
    displayText={span.text}
    markKey={glossaryData.markKey}
  />
) : (
  <Fragment set:html={inner} />
)}
{citationData.map(({ ref, index, markKey }) => (
  <Citation reference={ref} index={index} markKey={markKey} />
))}
