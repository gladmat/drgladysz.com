---
// src/components/content/GlossaryTerm.astro
//
// Renders a single in-text glossary mark as a dashed-underline span with a
// native HTML Popover tooltip. Hover (desktop) or tap (mobile) opens the
// popover; the Popover API toggles state declaratively via popovertarget,
// so zero JavaScript ships.
//
// The popover content shows the term, its category (mono caps), the short
// definition, and a "More about this term →" link to the dedicated glossary
// detail page. URL is locale-aware: /en/glossary/[slug] or /pl/slowniczek/[slug].
//
// Per-occurrence uniqueness: the popoverId includes the mark's `_key` so
// the same term cited multiple times in one article generates distinct
// popover ids (avoids the duplicate-id pattern flagged in CLAUDE.md
// open item #10 for citations).
import type { SanityGlossaryTerm } from '@/lib/sanity';

interface Props {
  term: SanityGlossaryTerm;
  displayText: string; // The text rendered in flow (may differ from canonical term)
  markKey: string; // Per-occurrence _key from the Portable Text mark
  locale?: 'en' | 'pl';
}

const { term, displayText, markKey, locale = 'en' } = Astro.props;

const definition =
  locale === 'pl' && term.shortDefinitionPolish
    ? term.shortDefinitionPolish
    : term.shortDefinition;

const displayedTerm =
  locale === 'pl' && term.termPolish ? term.termPolish : term.term;

const popoverId = `glossary-${term._id}-${markKey}`;

const CATEGORY_LABELS_EN: Record<SanityGlossaryTerm['category'], string> = {
  anatomy: 'Anatomy',
  condition: 'Condition',
  procedure: 'Procedure',
  investigation: 'Investigation',
  treatment: 'Treatment',
  outcome: 'Outcome measure',
  structure: 'Anatomical structure',
  other: 'Glossary',
};
const CATEGORY_LABELS_PL: Record<SanityGlossaryTerm['category'], string> = {
  anatomy: 'Anatomia',
  condition: 'Schorzenie',
  procedure: 'Zabieg',
  investigation: 'Badanie',
  treatment: 'Leczenie',
  outcome: 'Miara wyniku',
  structure: 'Struktura anatomiczna',
  other: 'Słowniczek',
};
const categoryLabels = locale === 'pl' ? CATEGORY_LABELS_PL : CATEGORY_LABELS_EN;
const categoryLabel = categoryLabels[term.category] ?? categoryLabels.other;

// Locale-aware detail-page URL. Polish slug "slowniczek" (diminutive of
// "słownik" — natural for "small dictionary," matches the popover-friendly
// tone). Both routes generate one page per glossaryTerm doc.
const detailUrl =
  locale === 'pl'
    ? `/pl/slowniczek/${term.slug.current}`
    : `/en/glossary/${term.slug.current}`;
const moreLinkLabel = locale === 'pl' ? 'Więcej o tym haśle' : 'More about this term';
---
<button
  type="button"
  class="glossary-trigger"
  popovertarget={popoverId}
  aria-label={`Definition of ${displayText}`}
  aria-describedby={popoverId}
  style={`anchor-name: --${popoverId}`}
>{displayText}</button><aside
  id={popoverId}
  popover="auto"
  class="glossary-popover"
  role="note"
  aria-labelledby={`${popoverId}-label`}
  style={`position-anchor: --${popoverId}`}
>
  <p class="glossary-popover-cat">{categoryLabel}</p>
  <h4 class="glossary-popover-term" id={`${popoverId}-label`}>{displayedTerm}</h4>
  <p class="glossary-popover-def">{definition}</p>
  <a class="glossary-popover-more" href={detailUrl}>
    {moreLinkLabel} <span aria-hidden="true">&rarr;</span>
  </a>
</aside>

<style>
  /* ---- In-flow trigger ------------------------------------------------- */
  .glossary-trigger {
    background: none;
    border: 0;
    padding: 0;
    color: inherit;
    font-family: inherit;
    font-size: inherit;
    line-height: inherit;
    font-style: inherit;
    font-weight: inherit;
    cursor: help;
    text-decoration: none;
    border-bottom: 1px dashed var(--ink-3);
    padding-bottom: 1px;
    transition: border-color 0.15s ease;
  }

  .glossary-trigger:hover,
  .glossary-trigger:focus-visible {
    border-bottom-color: var(--accent);
    border-bottom-style: solid;
  }

  .glossary-trigger:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: 1px;
  }

  /* ---- Popover --------------------------------------------------------- */
  /* Two-tier positioning:
     1) Baseline (all browsers): explicit center-of-viewport via fixed +
        inset: 0 + margin: auto. Reliable fallback when anchor positioning
        isn't supported.
     2) Modern browsers (CSS Anchor Positioning, Chrome 125+, Safari 17.4+,
        Firefox 130+): position-anchor (set per-instance via inline style
        using the popoverId) + position-area places the popover directly
        below the trigger, aligned to its right span.
     position-try-fallbacks lets the browser flip to top/left/right edges
     if the default placement would clip the viewport.

     Each trigger button + popover pair gets a unique anchor name via the
     inline `anchor-name` / `position-anchor` style attributes. The CSS
     here doesn't name the anchor — it consumes whatever the inline
     `position-anchor: --foo` declares. */
  .glossary-popover {
    position: fixed;
    inset: 0;
    width: fit-content;
    height: fit-content;
    margin: auto;
    border: 1px solid var(--rule-strong);
    background: var(--bg-card, var(--cream, #f5f0e6));
    color: var(--ink);
    padding: 16px 20px;
    max-width: min(360px, calc(100vw - 32px));
    border-radius: 0;
    box-shadow: 0 8px 24px rgba(20, 23, 26, 0.08);
  }

  @supports (position-area: bottom) {
    .glossary-popover {
      inset: auto;
      margin: 0;
      position-area: bottom span-right;
      margin-block-start: 8px;
      margin-inline-start: -2px;
      position-try-fallbacks:
        flip-block,
        flip-inline,
        flip-block flip-inline;
    }
  }

  .glossary-popover::backdrop {
    background: rgba(20, 23, 26, 0.04);
  }

  .glossary-popover-cat {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 6px;
  }

  .glossary-popover-term {
    font-family: var(--serif);
    font-weight: 500;
    font-size: 17px;
    line-height: 1.2;
    margin: 0 0 10px;
    color: var(--ink);
  }

  .glossary-popover-def {
    font-family: var(--sans);
    font-size: 14px;
    line-height: 1.55;
    color: var(--ink);
    margin: 0 0 12px;
  }

  .glossary-popover-more {
    display: inline-block;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid var(--accent);
    padding-bottom: 1px;
    transition: color 0.15s ease, border-color 0.15s ease;
  }

  .glossary-popover-more:hover,
  .glossary-popover-more:focus-visible {
    color: var(--ink);
    border-bottom-color: var(--ink);
  }

  .glossary-popover-more:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: 1px;
  }

  /* ---- Print ----------------------------------------------------------- */
  @media print {
    .glossary-trigger {
      border-bottom-style: dashed;
      cursor: default;
    }
    .glossary-popover {
      display: none !important;
    }
  }
</style>
