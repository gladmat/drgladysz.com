---
// src/components/content/Callout.astro
//
// Inline content callout — "info", "warning", or "pearl". Used both inside
// article body (rendered via PortableTextRenderer) and inside procedure
// sections. The three flavours share the same shape; only the accent rule
// and label colour differ.
//
// pearl — clinical pearl / pitfall (oxblood accent, default)
// info  — neutral aside (rule colour)
// warning — caution / red-flag (deeper oxblood, bolder rule)

interface Props {
  type?: 'info' | 'warning' | 'pearl';
  title?: string;
}

const { type = 'info', title } = Astro.props;

const labelByType: Record<string, string> = {
  info: 'Note',
  warning: 'Caution',
  pearl: 'Pearl',
};

const labelText = title || labelByType[type];
---
<aside class={`callout callout--${type}`} role="note">
  <p class="callout-label">{labelText}</p>
  <div class="callout-content">
    <slot />
  </div>
</aside>

<style>
  .callout {
    margin: 32px 0;
    padding: 20px 24px 4px;
    background: var(--bg-deep);
    border-left: 3px solid var(--rule-strong);
  }

  .callout--pearl {
    border-left-color: var(--accent);
  }

  .callout--warning {
    border-left-width: 4px;
    border-left-color: var(--accent);
    background: var(--bg-card);
    box-shadow: inset 0 0 0 1px var(--rule);
  }

  .callout-label {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 12px;
    font-weight: 500;
  }

  .callout--info .callout-label {
    color: var(--ink-3);
  }

  .callout-content :global(p) {
    font-family: var(--sans);
    font-size: 15px;
    line-height: 1.65;
    color: var(--ink);
    margin: 0 0 12px;
    max-width: none;
  }

  .callout-content :global(p:last-child) {
    margin-bottom: 16px;
  }

  .callout-content :global(strong) {
    color: var(--ink);
    font-weight: 600;
  }

  .callout-content :global(em) {
    font-style: italic;
  }
</style>
