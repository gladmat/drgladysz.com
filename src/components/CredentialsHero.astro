---
// CredentialsHero — single-column hero for the Credentials / Uprawnienia
// pages. Same eyebrow + master-wordmark + italic-standfirst register as
// AboutHero, but no image column (per credentials-page-package
// implementation brief §3 recommendation: no hero photo for v1.0/v1.1).
//
// Master wordmark per brand spec §2 + Decision #5: lowercase + cap M / cap G,
// both names upright, never italic. Same scale as About hero (clamp 40-72px).
interface Props {
  /** Mono caps eyebrow shown above the wordmark. e.g. "Credentials". */
  eyebrow: string;
  /** Italic standfirst paragraph. Allows inline HTML for italics on
   *  foreign-language terms — author-controlled, not user input. */
  leadHtml: string;
}

const { eyebrow, leadHtml } = Astro.props;
---
<section class="credentials-hero">
  <div class="hero-inner">
    <div class="hero-meta">
      <span class="accent-bar" aria-hidden="true"></span>
      <span>{eyebrow}</span>
    </div>
    <h1 class="hero-name">
      <span class="cap">M</span>ateusz <span class="second"><span class="cap">G</span>ładysz</span>
    </h1>
    <p class="hero-lead" set:html={leadHtml} />
  </div>
</section>

<style>
  .credentials-hero {
    padding-block: clamp(60px, 10vh, 120px) clamp(56px, 8vh, 96px);
    background: var(--bg);
  }
  .hero-inner {
    max-width: 1320px;
    margin: 0 auto;
    padding-inline: clamp(20px, 5vw, 80px);
  }
  .hero-meta {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 32px;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .accent-bar {
    width: 24px;
    height: 2px;
    background: var(--accent);
    display: inline-block;
  }
  .hero-name {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(40px, 6vw, 72px);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--ink);
    text-transform: lowercase;
    margin: 0 0 32px;
  }
  .hero-name .cap { text-transform: none; }
  .hero-name .second { display: block; }

  .hero-lead {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(18px, 1.6vw, 22px);
    line-height: 1.55;
    color: var(--ink-2);
    max-width: 60ch;
    margin: 0;
  }
  .hero-lead :global(em) { font-style: normal; }
  /* Inside an italic context, <em> reverts to normal so terms like
     *Facharzt* read italic against an italic standfirst. Standard
     opposite-style typography convention. */
</style>
