---
// AboutHero — master-wordmark hero for the About page.
//
// Composition (per _handoff/content/about-en.md hero spec, v1.6.2):
//   - "About" eyebrow with accent bar (mono 12px, 0.12em)
//   - H1 master wordmark Plex Serif Medium 500, clamp(40px, 6vw, 72px)
//     (slightly smaller than Home), line-height 1.05, letter-spacing -0.02em,
//     lowercase + cap M / cap G pattern, both names upright (never italic)
//   - Italic standfirst (Plex Serif Italic 18-22px, ink-2)
//   - Photo column: img-14 in 4:3, saturate(0.96)
//
// Per brand spec v1.8 §2 + Decision #5: web heroes use the master Medium
// 500 wordmark; no italic on the name in any context. The v1.6 spec
// directive "Gładysz upright italic 400" was an error and is corrected
// in v1.6.2 locked content.
//
// LCP image. Same shared-config technique as HomeHero so the BaseLayout
// preload srcset matches the <picture>'s AVIF source byte-for-byte.
import { Picture } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import {
  IMAGE_WIDTHS,
  IMAGE_QUALITY,
  IMAGE_SIZES_HERO_SPLIT,
  IMAGE_FORMATS,
} from '@/lib/image-config';

interface Props {
  photo: ImageMetadata;
  photoAlt: string;
  eyebrow?: string;
  lead: string;
}

const { photo, photoAlt, eyebrow = 'About', lead } = Astro.props;
---
<section class="about-hero">
  <div class="hero-inner">
    <div class="hero-grid">
      <div class="hero-text">
        <div class="hero-meta">
          <span class="accent-bar" aria-hidden="true"></span>
          <span>{eyebrow}</span>
        </div>
        <h1 class="hero-name">
          <span class="cap">M</span>ateusz <span class="second"><span class="cap">G</span>ładysz</span>
        </h1>
        <p class="hero-lead">{lead}</p>
      </div>
      <div class="hero-image">
        <Picture
          src={photo}
          alt={photoAlt}
          formats={[...IMAGE_FORMATS]}
          widths={[...IMAGE_WIDTHS]}
          sizes={IMAGE_SIZES_HERO_SPLIT}
          quality={IMAGE_QUALITY}
          loading="eager"
          decoding="async"
          fetchpriority="high"
          pictureAttributes={{ class: 'hero-picture' }}
        />
      </div>
    </div>
  </div>
</section>

<style>
  .about-hero {
    padding-block: clamp(60px, 10vh, 120px) clamp(80px, 14vh, 160px);
    background: var(--bg);
  }
  .hero-inner {
    max-width: 1320px;
    margin: 0 auto;
    padding-inline: clamp(20px, 5vw, 80px);
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 6fr 5fr;
    gap: clamp(40px, 6vw, 96px);
    align-items: center;
  }
  @media (max-width: 900px) {
    .hero-grid { grid-template-columns: 1fr; gap: 40px; }
  }

  .hero-meta {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 32px;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .accent-bar {
    width: 24px;
    height: 2px;
    background: var(--accent);
    display: inline-block;
  }

  .hero-name {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(40px, 6vw, 72px);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--ink);
    text-transform: lowercase;
    margin: 0 0 32px;
  }
  .hero-name .cap { text-transform: none; }
  .hero-name .second { display: block; }

  .hero-lead {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(18px, 1.6vw, 22px);
    line-height: 1.55;
    color: var(--ink-2);
    max-width: 38ch;
    margin: 0;
  }

  .hero-image {
    aspect-ratio: 4 / 3;
    background-color: var(--bg-deep);
    overflow: hidden;
  }
  .hero-image :global(.hero-picture),
  .hero-image :global(.hero-picture img) {
    display: block;
    width: 100%;
    height: 100%;
  }
  .hero-image :global(.hero-picture img) {
    object-fit: cover;
    object-position: center;
    filter: saturate(0.96);
  }
</style>
