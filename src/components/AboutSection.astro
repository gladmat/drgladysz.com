---
// AboutSection — numbered, labelled long-form section for About.
//
// Composition (per about-en.md and v1.6.2 mockup):
//   - Section masthead on top: 2-col grid 80px (mono "§ 0n" with accent
//     top border) + 1fr (mono uppercase label + h2 serif heading)
//   - Below the masthead: body + aside grid. Body in 720px / 64ch serif
//     column, aside in a narrower right column reserved for marginal
//     annotations (Tufte sidenote pattern; Phase 5 fills with citations,
//     pulled phrases, sidenotes).
//
// Aside slot defaults to an empty accent rule so the right column is
// visually intentional rather than accidentally empty. Consumers (or
// Phase 5 citation infrastructure) override the slot with marginal
// content as it becomes available.
interface Props {
  number: string;
  label: string;
  heading: string;
  headingId?: string;
  class?: string;
}

const { number, label, heading, headingId, class: className = '' } = Astro.props;
---
<section class:list={['about-section', className]}>
  <div class="about-inner">
    <header class="section-masthead">
      <div class="num">{number}</div>
      <div class="heading-block">
        <div class="label">{label}</div>
        <h2 id={headingId}>{heading}</h2>
      </div>
    </header>
    <div class="section-grid">
      <div class="section-body">
        <slot />
      </div>
      <aside class="section-aside">
        <slot name="aside">
          <span class="aside-bar" aria-hidden="true"></span>
        </slot>
      </aside>
    </div>
  </div>
</section>

<style>
  .about-section {
    padding-block: clamp(60px, 10vh, 120px);
    border-bottom: 1px solid var(--rule);
  }
  .about-inner {
    max-width: 1320px;
    margin: 0 auto;
    padding-inline: clamp(20px, 5vw, 80px);
  }

  .section-masthead {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 24px;
    align-items: baseline;
    margin-bottom: clamp(40px, 6vh, 56px);
  }
  @media (max-width: 600px) {
    .section-masthead { grid-template-columns: 1fr; gap: 16px; }
  }

  .num {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--accent);
    padding-top: 10px;
    border-top: 2px solid var(--accent);
    align-self: start;
  }

  .label {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin-bottom: 8px;
  }

  h2 {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(24px, 2.8vw, 34px);
    line-height: 1.2;
    letter-spacing: -0.018em;
    color: var(--ink);
    margin: 0;
  }

  /* Body + aside grid. Body sits in a 720px / 64ch reading column;
     aside is a ~200px right gutter reserved for marginal annotations
     (Phase 5 citation sidenotes will populate via the named slot). */
  .section-grid {
    display: grid;
    grid-template-columns: minmax(0, 720px) minmax(140px, 200px);
    gap: clamp(40px, 6vw, 96px);
    align-items: start;
  }
  @media (max-width: 900px) {
    .section-grid { grid-template-columns: 1fr; gap: 28px; }
  }

  .section-body { min-width: 0; }
  .section-body :global(p) {
    font-family: var(--serif);
    font-weight: 400;
    font-size: 17px;
    line-height: 1.7;
    color: var(--ink);
    margin: 0 0 22px;
    max-width: 64ch;
  }
  .section-body :global(p:last-child) { margin-bottom: 0; }
  .section-body :global(em) { font-style: italic; }
  .section-body :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
  }
  .section-body :global(a:hover) { color: var(--ink); }

  .section-aside {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-3);
    border-top: 2px solid var(--accent);
    padding-top: 14px;
    line-height: 1.5;
  }
  /* On mobile, aside is moved above body so it reads as a preview rather
     than an afterthought. Achieved with order swap. */
  @media (max-width: 900px) {
    .section-grid { grid-template-areas: "aside" "body"; }
    .section-body { grid-area: body; }
    .section-aside { grid-area: aside; }
  }
  .section-aside :global(.aside-bar) {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--accent);
  }
  .section-aside :global(.aside-num) {
    color: var(--accent);
    display: block;
    margin-bottom: 12px;
  }
  .section-aside :global(.aside-list) {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .section-aside :global(.aside-list li) {
    color: var(--ink-2);
  }
</style>
