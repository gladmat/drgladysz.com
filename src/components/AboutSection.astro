---
// AboutSection — numbered, labelled long-form section for About.
//
// Composition (per about-en.md and v1.6 mockup):
//   - Section masthead is a 2-column grid: 80px (mono "§ 0n" with accent
//     top border) + 1fr (mono uppercase label + h2 serif heading).
//   - Body content (slot) sits in a 720px max-width column with 17px / 1.7
//     serif paragraphs.
//
// Rendered as <section> with bottom rule; consumers chain multiple of these
// and the last one is unbordered via :last-of-type in the page-level CSS.
interface Props {
  number: string;
  label: string;
  heading: string;
  headingId?: string;
  class?: string;
}

const { number, label, heading, headingId, class: className = '' } = Astro.props;
---
<section class:list={['about-section', className]}>
  <div class="about-inner">
    <header class="section-masthead">
      <div class="num">{number}</div>
      <div class="heading-block">
        <div class="label">{label}</div>
        <h2 id={headingId}>{heading}</h2>
      </div>
    </header>
    <div class="section-body">
      <slot />
    </div>
  </div>
</section>

<style>
  .about-section {
    padding-block: clamp(60px, 10vh, 120px);
    border-bottom: 1px solid var(--rule);
  }
  .about-inner {
    max-width: 1320px;
    margin: 0 auto;
    padding-inline: clamp(20px, 5vw, 80px);
  }

  .section-masthead {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 24px;
    align-items: baseline;
    margin-bottom: clamp(40px, 6vh, 56px);
  }
  @media (max-width: 600px) {
    .section-masthead { grid-template-columns: 1fr; gap: 16px; }
  }

  .num {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--accent);
    padding-top: 10px;
    border-top: 2px solid var(--accent);
    align-self: start;
  }

  .label {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin-bottom: 8px;
  }

  h2 {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(24px, 2.8vw, 34px);
    line-height: 1.2;
    letter-spacing: -0.018em;
    color: var(--ink);
    margin: 0;
  }

  .section-body { max-width: 720px; }
  .section-body :global(p) {
    font-family: var(--serif);
    font-weight: 400;
    font-size: 17px;
    line-height: 1.7;
    color: var(--ink);
    margin: 0 0 22px;
    max-width: 64ch;
  }
  .section-body :global(p:last-child) { margin-bottom: 0; }
  .section-body :global(em) { font-style: italic; }
  .section-body :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
  }
  .section-body :global(a:hover) { color: var(--ink); }
</style>
