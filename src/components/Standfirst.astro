---
// Standfirst — single long-form lead paragraph in Plex Serif, with a
// right-margin aside slot for marginal annotations (Tufte sidenote pattern).
//
// Layout: 2-column grid on desktop (≥900px) — body left, aside right with
// a narrower fixed width. Stacks on mobile (aside above body, so it reads
// as a section preview / index before the long paragraph).
//
// The aside is a slot. Default is empty (a thin accent rule for visual
// continuity with the section). Consumers can pass a marginal index, a
// pulled phrase, structural metadata (§ 0n), or — in Phase 5 — citation
// references.
interface Props {
  body?: string;
  // Use bodyHtml when the paragraph contains inline markup (e.g. <em> around
  // foreign-language terms per editorial convention #2). Mirrors the
  // titleHtml / leadHtml convention used in PublicationsTeaser and
  // CredentialsHero. bodyHtml takes precedence over body if both are passed.
  bodyHtml?: string;
  bodyMaxWidth?: string;
}

const { body, bodyHtml, bodyMaxWidth = '760px' } = Astro.props;
---
<section class="standfirst-section">
  <div class="standfirst-inner">
    <div class="standfirst-grid" style={`--standfirst-body-max: ${bodyMaxWidth}`}>
      <div class="standfirst-body">
        {bodyHtml
          ? <p set:html={bodyHtml} />
          : body
            ? <p>{body}</p>
            : <slot />}
      </div>
      <aside class="standfirst-aside">
        <slot name="aside">
          <span class="aside-bar" aria-hidden="true"></span>
        </slot>
      </aside>
    </div>
  </div>
</section>

<style>
  .standfirst-section {
    padding-block: clamp(60px, 10vh, 100px) clamp(80px, 12vh, 120px);
    border-top: 1px solid var(--rule);
    background: var(--bg);
  }
  .standfirst-inner {
    max-width: 1320px;
    margin: 0 auto;
    padding-inline: clamp(20px, 5vw, 80px);
  }

  /* Desktop: body left in a 760px / 60ch reading column, aside right
     as a narrow ~200px sidenote column (Tufte sidenote convention).
     Mobile: stack with aside ABOVE body so the marginal index reads
     as a section preview rather than an afterthought. */
  .standfirst-grid {
    display: grid;
    grid-template-columns: minmax(0, var(--standfirst-body-max, 760px)) minmax(140px, 200px);
    gap: clamp(40px, 6vw, 96px);
    align-items: start;
  }
  @media (max-width: 900px) {
    .standfirst-grid {
      grid-template-columns: 1fr;
      grid-template-areas: "aside" "body";
      gap: 28px;
    }
    .standfirst-body { grid-area: body; }
    .standfirst-aside { grid-area: aside; }
  }

  .standfirst-body {
    min-width: 0;
  }
  .standfirst-body :global(p) {
    /* Body large per brand spec v1.8 type scale: Plex Sans 400 / 18 / 1.60.
       The clamp keeps the 18 px minimum (= spec) and adds a small responsive
       upper bound for wide viewports, where the lead paragraph reads as the
       page's emphasis register relative to the 16 px card body. */
    font-family: var(--sans);
    font-weight: 400;
    font-size: clamp(18px, 1.85vw, 22px);
    line-height: 1.6;
    color: var(--ink);
    max-width: 60ch;
    margin: 0;
  }

  .standfirst-aside {
    /* Editorial mono register; oxblood low-frequency, top accent rule. */
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-3);
    border-top: 2px solid var(--accent);
    padding-top: 14px;
    line-height: 1.5;
  }
  .standfirst-aside :global(.aside-bar) {
    /* Visible only when the slot fallback runs — keeps the column from
       collapsing without imposing text content. */
    display: block;
    width: 24px;
    height: 2px;
    background: var(--accent);
  }
  .standfirst-aside :global(.aside-num) {
    color: var(--accent);
    display: block;
    margin-bottom: 12px;
  }
  .standfirst-aside :global(.aside-label) {
    color: var(--ink-3);
    display: block;
    margin-bottom: 12px;
  }
  .standfirst-aside :global(.aside-list) {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .standfirst-aside :global(.aside-list li) {
    color: var(--ink-2);
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
</style>
