---
// src/pages/en/glossary/index.astro
//
// Glossary index — A-Z list of every published glossary term. Source: Sanity
// `glossaryTerm` documents. Sort and grouping happen in JS using
// Intl.Collator('en') for consistent locale-aware ordering. Pure CSS layout,
// zero JS shipped.
//
// Each term card links to `/en/glossary/[slug]`. The same Sanity doc backs
// the Polish counterpart at `/pl/slowniczek/[slug]` via the alternateUrl
// pattern below — the doc holds both EN and PL fields side by side.
//
// Schema.org `DefinedTermSet` JSON-LD lists every term with its short
// definition and detail-page URL — surfaces the full glossary as structured
// data on the index alone.
import SiteLayout from '@/layouts/SiteLayout.astro';
import SectionMasthead from '@/components/SectionMasthead.astro';
import { getAllGlossaryTerms, type GlossarySummary } from '@/lib/sanity';
import { generateDefinedTermSetSchema, generateBreadcrumb } from '@/lib/schema';

const terms = await getAllGlossaryTerms();

const CATEGORY_LABELS: Record<GlossarySummary['category'], string> = {
  anatomy: 'Anatomy',
  condition: 'Condition',
  procedure: 'Procedure',
  investigation: 'Investigation',
  treatment: 'Treatment',
  outcome: 'Outcome measure',
  structure: 'Anatomical structure',
  other: 'Glossary',
};

const collator = new Intl.Collator('en', { sensitivity: 'base' });
const sorted = [...terms].sort((a, b) => collator.compare(a.term, b.term));

// Group by uppercased first letter of the English term.
const groupMap = new Map<string, GlossarySummary[]>();
for (const term of sorted) {
  const letter = term.term.charAt(0).toUpperCase() || '#';
  const list = groupMap.get(letter) ?? [];
  list.push(term);
  groupMap.set(letter, list);
}
const grouped = Array.from(groupMap.entries()).map(([letter, items]) => ({
  letter,
  items,
}));
const letters = grouped.map((g) => g.letter);

const totalCount = terms.length;

const siteUrl = (
  import.meta.env.PUBLIC_SITE_URL || 'https://drgladysz.com'
).replace(/\/$/, '');
const canonicalUrl = `${siteUrl}/en/glossary/`;

const definedTermSetJsonLd = generateDefinedTermSetSchema({
  url: canonicalUrl,
  name: 'Hand-surgery glossary — Mateusz Gładysz, MD',
  description:
    'Plain-language definitions of anatomical structures, conditions, procedures, and outcome measures relevant to hand and reconstructive surgery.',
  inLanguage: 'en-NZ',
  terms,
  termUrlPrefix: `${siteUrl}/en/glossary/`,
  locale: 'en',
});

const breadcrumbJsonLd = generateBreadcrumb([
  { name: 'Home', url: `${siteUrl}/en/` },
  { name: 'Glossary', url: canonicalUrl },
]);
---
<SiteLayout
  title="Glossary — Mateusz Gładysz, MD"
  description="Hand-surgery glossary: anatomical structures, conditions, procedures, investigations, and outcome measures defined in clinical context."
  locale="en"
  alternateUrl="/pl/slowniczek/"
  canonical={canonicalUrl}
  jsonLd={[definedTermSetJsonLd, breadcrumbJsonLd]}
>
  <section class="index-masthead-shell">
    <SectionMasthead
      label="Glossary"
      heading="Hand-surgery terms, defined"
      headingTag="h1"
      standfirst="A working reference of the anatomical structures, conditions, procedures, investigations, and outcome measures that recur across the articles and procedure pages on this site. Each entry is written in plain language for patients and links to the underlying clinical context."
    />
    {totalCount > 0 && (
      <nav class="letter-nav" aria-label="Jump to letter">
        <ul>
          {letters.map((letter) => (
            <li>
              <a href={`#letter-${letter}`}>{letter}</a>
            </li>
          ))}
        </ul>
      </nav>
    )}
  </section>

  <section class="glossary-index">
    <div class="glossary-index-inner">
      {totalCount === 0 ? (
        <div class="empty">
          <p>The glossary is in preparation. Check back shortly.</p>
        </div>
      ) : (
        grouped.map((group) => (
          <section
            class="letter-section"
            id={`letter-${group.letter}`}
            aria-labelledby={`letter-h-${group.letter}`}
          >
            <h2 id={`letter-h-${group.letter}`} class="letter-heading">
              {group.letter}
            </h2>
            <ol class="term-list">
              {group.items.map((term) => (
                <li class="term-card">
                  <a
                    href={`/en/glossary/${term.slug.current}`}
                    class="term-card-link"
                  >
                    <p class="card-meta">
                      <span class="card-cat">
                        {CATEGORY_LABELS[term.category]}
                      </span>
                      {term.termPolish && term.termPolish !== term.term && (
                        <>
                          <span aria-hidden="true">·</span>
                          <span class="card-pl" lang="pl">
                            {term.termPolish}
                          </span>
                        </>
                      )}
                    </p>
                    <h3 class="card-term">{term.term}</h3>
                    <p class="card-def">{term.shortDefinition}</p>
                  </a>
                </li>
              ))}
            </ol>
          </section>
        ))
      )}
    </div>
  </section>
</SiteLayout>

<style>
  .index-masthead-shell {
    padding: clamp(56px, 8vw, 120px) clamp(20px, 5vw, 80px) 0;
    max-width: 1320px;
    margin: 0 auto;
  }

  .letter-nav {
    margin-top: 40px;
    padding: 16px 0;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    position: sticky;
    top: 0;
    z-index: 10;
    background: var(--bg);
  }

  .letter-nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 4px 14px;
  }

  .letter-nav a {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: var(--ink-2);
    text-decoration: none;
    padding: 4px 6px;
    border-bottom: 1px solid transparent;
    transition: color 0.15s ease, border-color 0.15s ease;
  }

  .letter-nav a:hover,
  .letter-nav a:focus-visible {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }

  .letter-nav a:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: 1px;
  }

  .glossary-index {
    padding: clamp(40px, 6vw, 80px) 0 120px;
  }

  .glossary-index-inner {
    max-width: 1320px;
    margin: 0 auto;
    padding-inline: clamp(20px, 5vw, 80px);
  }

  .empty {
    max-width: 60ch;
    font-family: var(--serif);
    font-style: italic;
    font-size: 18px;
    color: var(--ink-2);
  }

  .letter-section {
    margin-bottom: clamp(56px, 8vw, 96px);
    /* Pull anchor target above sticky letter-nav (~56px tall) so jump-link
       lands the heading in view. */
    scroll-margin-top: 80px;
  }

  .letter-heading {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(56px, 8vw, 96px);
    line-height: 1;
    color: var(--accent);
    margin: 0 0 32px;
    letter-spacing: -0.03em;
    border-bottom: 1px solid var(--rule);
    padding-bottom: 16px;
  }

  .term-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 32px;
    grid-template-columns: 1fr;
  }

  @media (min-width: 700px) {
    .term-list {
      grid-template-columns: 1fr 1fr;
      column-gap: 48px;
    }
  }

  .term-card {
    border-top: 1px solid var(--rule);
    padding-top: 20px;
  }

  .term-card-link {
    display: grid;
    gap: 8px;
    text-decoration: none;
    color: inherit;
  }

  .term-card-link:hover .card-term {
    color: var(--accent);
  }

  .term-card-link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 6px;
  }

  .card-meta {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.10em;
    color: var(--ink-3);
    margin: 0;
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .card-cat {
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .card-pl {
    font-style: italic;
    color: var(--ink-3);
  }

  .card-term {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(20px, 2vw, 24px);
    line-height: 1.2;
    color: var(--ink);
    margin: 0;
    letter-spacing: -0.012em;
    transition: color 0.15s ease;
  }

  .card-def {
    font-family: var(--serif);
    font-size: 16px;
    line-height: 1.55;
    color: var(--ink-2);
    margin: 0;
    max-width: 60ch;
  }
</style>
