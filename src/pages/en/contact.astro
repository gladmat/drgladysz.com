---
// src/pages/en/contact.astro
//
// Form submits to /api/contact (Resend-backed POST endpoint at
// src/pages/api/contact.ts; opt-in to SSR via prerender=false). The
// progressive-enhancement script intercepts submit, fetches /api/contact,
// and renders status in the form's aria-live region. Without JS the form
// posts natively and the browser shows the JSON response.
//
// Per the brand spec / compliance checklist: no live chat widgets, no
// patient images, no testimonials, no third-party form embeds (Typeform,
// Formspree, etc.).
import SiteLayout from '@/layouts/SiteLayout.astro';
import ContentPage from '@/components/ContentPage.astro';
---
<SiteLayout
  title="Contact — Mateusz Gładysz, MD"
  description="How to make contact for clinical referrals, editorial questions about the site, or professional correspondence."
  locale="en"
>
  <ContentPage
    label="Contact"
    title="Contact"
    standfirst="The most reliable way to make contact is by email. Clinical referrals follow standard professional pathways through the relevant hospital or registrar."
  >
    <h2>Email</h2>
    <p>
      <a href="mailto:mateusz@drgladysz.com">mateusz@drgladysz.com</a>
    </p>
    <p>
      Editorial corrections, citation requests, and questions about the content of this site are answered as time allows &mdash; usually within a week. Professional correspondence on training, research, and society matters is welcome.
    </p>

    <h2>Clinical referrals</h2>
    <p>
      I am a Senior Medical Officer in the Department of Plastic Surgery at <strong>Waikato Hospital, Hamilton, New Zealand</strong>. Public-system referrals from a general practitioner or specialist follow the usual Waikato pathway. Private and second-opinion referrals are accepted through the standard professional channels; if you are a referring practitioner please make contact via the email above so we can identify the right pathway for the case.
    </p>
    <p>
      Polish-language consultations may be arranged for patients in New Zealand who prefer Polish. Polish practice in Poland itself is being formally activated separately &mdash; details will appear on this page when available.
    </p>

    <h2>Languages</h2>
    <p>
      Consultations are conducted in English, Polish, and German.
    </p>

    <h2>Send a message</h2>
    <p class="form-note">
      Submit the form below and the message reaches the inbox above. Nothing is stored on the server — once sent, the message lives only in the recipient mailbox.
    </p>
    <form
      action="/api/contact"
      method="post"
      class="contact-form"
      data-contact-form
    >
      <div class="hp-field" aria-hidden="true">
        <label for="contact-website">Website (leave empty)</label>
        <input
          id="contact-website"
          name="website"
          type="text"
          tabindex="-1"
          autocomplete="off"
        />
      </div>
      <div class="field">
        <label for="contact-name">Name</label>
        <input
          id="contact-name"
          name="Name"
          type="text"
          autocomplete="name"
          required
        />
      </div>
      <div class="field">
        <label for="contact-from">Your email</label>
        <input
          id="contact-from"
          name="Email"
          type="email"
          autocomplete="email"
          required
        />
      </div>
      <div class="field">
        <label for="contact-context">Context</label>
        <select id="contact-context" name="Context" required>
          <option value="">Select…</option>
          <option value="clinical">Clinical referral / second opinion</option>
          <option value="editorial">Editorial correction / citation request</option>
          <option value="professional">Professional correspondence (training, research, society)</option>
          <option value="other">Other</option>
        </select>
      </div>
      <div class="field">
        <label for="contact-message">Message</label>
        <textarea
          id="contact-message"
          name="Message"
          rows="6"
          required
        ></textarea>
      </div>
      <button type="submit" class="contact-submit">Send message</button>
      <p class="form-status" data-contact-status role="status" aria-live="polite"></p>
    </form>
    <script is:inline>
      (() => {
        const form = document.querySelector('[data-contact-form]');
        if (!form) return;
        const status = form.querySelector('[data-contact-status]');
        const submit = form.querySelector('button[type="submit"]');
        const ERRORS = {
          invalid_name: 'Please enter your name.',
          invalid_email: 'Please enter a valid email address.',
          invalid_context: 'Please select a context.',
          invalid_message: 'Please write a message of at least 10 characters.',
          rate_limited: 'Please wait a minute before sending another message.',
          send_failed: 'Could not send right now. Please try again or email mateusz@drgladysz.com directly.',
          server_misconfigured: 'The form is temporarily unavailable. Please email mateusz@drgladysz.com directly.',
        };
        form.addEventListener('submit', async (event) => {
          event.preventDefault();
          submit.disabled = true;
          status.textContent = 'Sending…';
          status.className = 'form-status';
          try {
            const response = await fetch('/api/contact', {
              method: 'POST',
              body: new FormData(form),
            });
            const result = await response.json();
            if (result.ok) {
              status.textContent = 'Thank you. Your message has been sent.';
              status.className = 'form-status is-success';
              form.reset();
            } else {
              status.textContent = ERRORS[result.error] || 'Something went wrong. Please try again or email mateusz@drgladysz.com directly.';
              status.className = 'form-status is-error';
            }
          } catch {
            status.textContent = 'Network error. Please try again or email mateusz@drgladysz.com directly.';
            status.className = 'form-status is-error';
          } finally {
            submit.disabled = false;
          }
        });
      })();
    </script>

    <h2>What this page is not</h2>
    <p>
      This is not a portal for emergency advice, prescription requests, or remote diagnosis. If you have an urgent medical concern, contact your local emergency services. In New Zealand: 111. In Poland and the European Union: 112.
    </p>
    <p>
      The site does not collect any personal data beyond what you choose to include in an email. See the <a href="/en/privacy">privacy policy</a> for the full data-handling description, and the <a href="/en/disclaimer">medical disclaimer</a> for the scope of educational content here.
    </p>
  </ContentPage>
</SiteLayout>

<style>
  .contact-form {
    display: grid;
    gap: 20px;
    margin: 32px 0 24px;
    max-width: 560px;
  }

  .field {
    display: grid;
    gap: 6px;
  }

  .field label {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: var(--ink-3);
  }

  .field input,
  .field select,
  .field textarea {
    font-family: var(--sans);
    font-size: 16px;
    line-height: 1.5;
    color: var(--ink);
    background: var(--bg-card);
    border: 1px solid var(--rule-strong);
    border-radius: 0;
    padding: 10px 12px;
    width: 100%;
  }

  .field input:focus,
  .field select:focus,
  .field textarea:focus {
    outline: 2px solid var(--accent);
    outline-offset: 0;
    border-color: var(--accent);
  }

  .field textarea {
    resize: vertical;
    min-height: 140px;
    font-family: var(--serif);
    font-size: 17px;
    line-height: 1.55;
  }

  .contact-submit {
    justify-self: start;
    font-family: var(--mono);
    font-size: 13px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--bg);
    background: var(--accent);
    border: 0;
    padding: 12px 24px;
    cursor: pointer;
    border-radius: 0;
  }

  .contact-submit:hover {
    background: var(--ink);
  }

  .contact-submit:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 4px;
  }

  .form-note {
    font-family: var(--serif);
    font-style: italic;
    font-size: 16px;
    color: var(--ink-3);
    margin: 16px 0 0;
    max-width: 60ch;
  }

  /* Honeypot field — visually hidden but accessible to bots that fill
     every field, and to screen readers that announce the warning label. */
  .hp-field {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .form-status {
    font-family: var(--sans);
    font-size: 14px;
    line-height: 1.55;
    color: var(--ink-2);
    margin: 0;
    min-height: 1.55em;
  }
  .form-status.is-success { color: var(--accent); }
  .form-status.is-error { color: var(--ink); font-weight: 600; }
</style>
