---
// src/pages/en/blog/[slug].astro
//
// Article detail page. Statically generates one page per published article in
// Sanity. The route is `getStaticPaths`-driven, so when there are no articles
// (Phase 5 baseline) the route resolves to zero generated pages and the build
// is clean.
//
// Layout responsibilities:
//   - Sidenote gutter: `.article-content` reserves padding-right: 320px on
//     desktop ≥1024px so Citation.astro's right-floated sidenote lands clear
//     of the body. Below 1024px, citations open as native HTML popovers from
//     the inline marker.
//   - Heading sequence:
//        H1 (article title) → KeyPoints box → ARTICLE BODY (PortableText)
//        → Bibliography (numbered references)
//   - Schema.org JSON-LD: MedicalScholarlyArticle (peer/expert) or
//     MedicalWebPage (patient), populated via lib/schema.ts.
import SiteLayout from '@/layouts/SiteLayout.astro';
import KeyPoints from '@/components/content/KeyPoints.astro';
import Bibliography from '@/components/content/Bibliography.astro';
import PortableTextRenderer from '@/components/content/PortableTextRenderer.astro';
import {
  getAllArticleSlugs,
  getArticleBySlug,
  getReferencesByIds,
  getGlossaryTermsByIds,
  extractCitationOrderFromBlocks,
  extractGlossaryOrderFromBlocks,
  urlForImage,
} from '@/lib/sanity';
import { generateArticleSchema, generateBreadcrumb } from '@/lib/schema';

export async function getStaticPaths() {
  const slugs = await getAllArticleSlugs('en');
  return slugs.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
if (!slug) throw new Error('Missing slug param');

const article = await getArticleBySlug(slug, 'en');
if (!article) {
  // Sanity returned no doc with this slug — let Astro 404 handle it.
  return Astro.redirect('/en/blog/');
}

// EN→PL slug map for hreflang (alternateUrl). Authored explicitly so the
// reverse direction is obvious; falls back to none (no alternate emitted) for
// EN-only articles. Update this when adding new EN articles that have a PL
// counterpart. (Mirror of the PL→EN map at pl/blog/[slug].astro.)
const EN_TO_PL_SLUG: Record<string, string> = {
  'carpal-tunnel-syndrome': 'zespol-ciesni-nadgarstka',
  'carpal-tunnel-syndrome-fessh-prep': 'zespol-ciesni-nadgarstka-przeglad-kliniczny',
  'dupuytrens-disease-patient-guide': 'choroba-dupuytrena',
  // 'dupuytrens-disease-fessh-prep' has no direct PL counterpart — the PL
  // package's expert article is operative-treatment focused (Decision-tree-
  // for-method-choice angle), different audience/angle from FESSH-prep.
};
const plSlug = EN_TO_PL_SLUG[slug];
const alternateUrl = plSlug ? `/pl/blog/${plSlug}/` : undefined;

// Collect citation references in document order, then load.
const citationOrder = extractCitationOrderFromBlocks([article.body]);
const referencesUnsorted = await getReferencesByIds(citationOrder);
const references = citationOrder
  .map((id) => referencesUnsorted.find((r) => r._id === id))
  .filter((r): r is NonNullable<typeof r> => Boolean(r));

// Collect glossary-term references and load. Order doesn't drive numbering
// (unlike citations) — the lookup is keyed by _id.
const glossaryOrder = extractGlossaryOrderFromBlocks([article.body]);
const glossaryTerms = await getGlossaryTermsByIds(glossaryOrder);

const siteUrl = (
  import.meta.env.PUBLIC_SITE_URL || 'https://drgladysz.com'
).replace(/\/$/, '');
const canonicalUrl = `${siteUrl}/en/blog/${slug}/`;

// Hero image data for the JSON-LD ImageObject. We render at 1200×800 for a
// rich-snippet-friendly aspect; the visible <img> below uses a separate URL
// at 2000px wide for sharp display. Both URLs hit the same Sanity asset.
const articleHeroImageData = article.heroImage
  ? {
      url: urlForImage(article.heroImage).width(1200).height(800).fit('crop').url(),
      width: 1200,
      height: 800,
      alt: article.heroImage.alt,
    }
  : undefined;

const articleJsonLd = generateArticleSchema({
  article,
  references,
  url: canonicalUrl,
  heroImage: articleHeroImageData,
});

const breadcrumbJsonLd = generateBreadcrumb([
  { name: 'Home', url: `${siteUrl}/en/` },
  { name: 'Knowledge base', url: `${siteUrl}/en/blog/` },
  { name: article.title, url: canonicalUrl },
]);

const publishedDateLabel = new Date(article.publishedDate).toLocaleDateString(
  'en-NZ',
  { year: 'numeric', month: 'long', day: 'numeric' },
);
const updatedDateLabel = article.lastUpdated
  ? new Date(article.lastUpdated).toLocaleDateString('en-NZ', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null;

const heroImageUrl = article.heroImage
  ? urlForImage(article.heroImage).width(2000).fit('max').url()
  : null;

const categoryLabel: Record<string, string> = {
  patient: 'Patient information',
  expert: 'Expert blog',
  'fessh-prep': 'FESSH preparation',
  news: 'News & commentary',
};

// Author byline. The brand convention renders the name and post-nominals
// mid-dot-separated ("Mateusz Gładysz · MD · FEBOPRAS · FEBHS").
//
// The Phase 5 seed populated post-nominals under a non-schema `title` field
// (and put the role string into `credentials`), so we look in both fields
// and pick whichever segment looks like post-nominals — comma-separated
// short uppercase tokens. Newly authored author docs that follow the schema
// will store post-nominals in `credentials` and this logic still works.
const POSTNOM_PATTERN = /^[A-Z][A-Za-z0-9]*$/;
function postNominalSegments(value: string | undefined): string[] {
  if (!value) return [];
  const parts = value.split(',').map((s) => s.trim()).filter(Boolean);
  return parts.every((p) => POSTNOM_PATTERN.test(p)) ? parts : [];
}
const authorPostNominals = article.author
  ? postNominalSegments(article.author.credentials).length > 0
    ? postNominalSegments(article.author.credentials)
    : postNominalSegments(article.author.title)
  : [];
const authorByline = article.author
  ? [article.author.name, ...authorPostNominals].join(' · ')
  : null;

// Standfirst falls back to excerpt for articles authored before the schema
// gained a dedicated standfirst field (carpal-tunnel-syndrome).
const standfirstText = article.standfirst?.trim() || article.excerpt;

// Drop unresolved related references (target document deleted). The GROQ
// projection returns null for unresolved refs in the array.
const relatedArticles = (article.relatedArticles ?? []).filter(
  (a): a is NonNullable<typeof a> => Boolean(a),
);
const relatedProcedures = (article.relatedProcedures ?? []).filter(
  (p): p is NonNullable<typeof p> => Boolean(p),
);
const hasRelated = relatedArticles.length > 0 || relatedProcedures.length > 0;

const articleCategoryLabel: Record<string, string> = {
  patient: 'Patient information',
  expert: 'Expert blog',
  'fessh-prep': 'FESSH preparation',
  news: 'News & commentary',
};
const procedureCategoryLabel: Record<string, string> = {
  'hand-surgery': 'Hand surgery',
  'reconstructive-microsurgery': 'Reconstructive & microsurgery',
  'skin-cancer': 'Skin cancer surgery',
};
---
<SiteLayout
  title={article.seoTitle || `${article.title} — Mateusz Gładysz, MD`}
  description={article.seoDescription || article.excerpt}
  locale="en"
  canonical={canonicalUrl}
  alternateUrl={alternateUrl}
  jsonLd={[articleJsonLd, breadcrumbJsonLd]}
>
  <article class="article-shell">
    <header class="article-header">
      <p class="article-kicker">
        <a href="/en/blog/">Knowledge base</a>
        <span aria-hidden="true">·</span>
        <span>{categoryLabel[article.category] ?? article.category}</span>
      </p>
      <h1 class="article-title">{article.title}</h1>
      {authorByline && <p class="article-byline">{authorByline}</p>}
      {standfirstText && <p class="article-standfirst">{standfirstText}</p>}
      <p class="article-meta">
        <span>
          Published <time datetime={article.publishedDate}>{publishedDateLabel}</time>
        </span>
        {updatedDateLabel && (
          <>
            <span aria-hidden="true">·</span>
            <span>
              Last clinically reviewed <time datetime={article.lastUpdated}>{updatedDateLabel}</time>
            </span>
          </>
        )}
      </p>
    </header>

    {heroImageUrl && (
      <figure class="article-hero">
        <img
          src={heroImageUrl}
          alt={article.heroImage?.alt ?? ''}
          loading="eager"
          decoding="async"
        />
      </figure>
    )}

    <div class="article-content">
      {article.keyPoints && (
        <KeyPoints
          question={article.keyPoints.question}
          findings={article.keyPoints.findings}
          meaning={article.keyPoints.meaning}
        />
      )}

      <div class="article-body">
        <PortableTextRenderer
          value={article.body}
          references={references}
          glossaryTerms={glossaryTerms}
        />
      </div>

      <Bibliography references={references} />

      {hasRelated && (
        <aside class="article-related" aria-labelledby="related-heading">
          <h2 id="related-heading" class="related-heading">Related</h2>
          {relatedArticles.length > 0 && (
            <section class="related-section">
              <p class="related-kicker">Articles</p>
              <ul class="related-list">
                {relatedArticles.map((a) => (
                  <li>
                    <a href={`/en/blog/${a.slug.current}`}>
                      <span class="related-title">{a.title}</span>
                      <span class="related-meta">{articleCategoryLabel[a.category] ?? a.category}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          )}
          {relatedProcedures.length > 0 && (
            <section class="related-section">
              <p class="related-kicker">Procedures</p>
              <ul class="related-list">
                {relatedProcedures.map((p) => (
                  <li>
                    <a href={`/en/procedures/${p.slug.current}`}>
                      <span class="related-title">{p.title}</span>
                      <span class="related-meta">{procedureCategoryLabel[p.category] ?? p.category}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          )}
        </aside>
      )}
    </div>
  </article>
</SiteLayout>

<style>
  .article-shell {
    max-width: 1320px;
    margin: 0 auto;
    padding: clamp(40px, 7vw, 96px) clamp(20px, 5vw, 80px) 120px;
  }

  .article-header {
    margin-bottom: clamp(40px, 6vw, 80px);
    max-width: 760px;
  }

  .article-kicker {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin: 0 0 24px;
    display: flex;
    gap: 12px;
    align-items: center;
  }

  .article-kicker a {
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid var(--accent);
    padding-bottom: 1px;
  }

  .article-kicker a:hover {
    color: var(--ink);
    border-bottom-color: var(--ink);
  }

  .article-title {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(34px, 5vw, 56px);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin: 0 0 16px;
  }

  .article-byline {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 24px;
  }

  .article-standfirst {
    font-family: var(--serif);
    font-style: italic;
    font-size: clamp(18px, 1.6vw, 22px);
    line-height: 1.55;
    color: var(--ink-2);
    margin: 0 0 28px;
    max-width: 60ch;
  }

  .article-meta {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.06em;
    color: var(--ink-3);
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin: 0;
  }

  .article-hero {
    margin: 0 0 64px;
  }

  .article-hero img {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 16/9;
    object-fit: cover;
  }

  /* Body container — reserves a 320px right gutter on desktop ≥1024px so
     <Citation>'s right-floated sidenote can land in the margin without
     overlapping prose. Below 1024px the gutter collapses and citations open
     as native popovers from the inline marker. */
  .article-content {
    max-width: 720px;
    margin: 0;
    position: relative;
  }

  @media (min-width: 1024px) {
    .article-content {
      padding-right: 320px;
      max-width: 1040px;
    }
  }

  .article-body {
    /* clearfix so floated sidenotes don't bleed past the body */
  }

  .article-body::after {
    content: '';
    display: block;
    clear: both;
  }

  /* Related — sibling articles + procedures surfaced after Bibliography. */
  .article-related {
    margin-top: clamp(48px, 6vw, 80px);
    padding-top: 32px;
    border-top: 1px solid var(--ink-3);
  }

  .related-heading {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin: 0 0 24px;
  }

  .related-section {
    margin-bottom: 24px;
  }

  .related-section:last-child {
    margin-bottom: 0;
  }

  .related-kicker {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 12px;
  }

  .related-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .related-list li {
    margin: 0;
    padding: 0;
    border-top: 1px solid color-mix(in oklab, var(--ink-3) 30%, transparent);
  }

  .related-list li:last-child {
    border-bottom: 1px solid color-mix(in oklab, var(--ink-3) 30%, transparent);
  }

  .related-list a {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 16px;
    padding: 14px 0;
    text-decoration: none;
    color: var(--ink);
  }

  .related-list a:hover .related-title {
    color: var(--accent);
  }

  .related-title {
    font-family: var(--serif);
    font-size: 18px;
    line-height: 1.35;
  }

  .related-meta {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-3);
    flex-shrink: 0;
  }
</style>
