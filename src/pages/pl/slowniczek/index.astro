---
// src/pages/pl/slowniczek/index.astro
//
// Polish counterpart of /en/glossary. Same data source — every Sanity
// glossaryTerm doc holds both EN and PL fields side by side. The page
// displays termPolish where present, falling back to the English term in
// italics with a small "EN" tag (so untranslated terms remain discoverable).
//
// Sort uses Intl.Collator('pl') so Polish diacritics (Ł, Ó, Ś, Ź, Ż, …)
// group correctly and don't fold into their unaccented bases.
//
// Polish chrome (masthead label, standfirst, category labels) is a working
// draft — flag for revision in the Polish composition session before launch.
import SiteLayout from '@/layouts/SiteLayout.astro';
import SectionMasthead from '@/components/SectionMasthead.astro';
import { getAllGlossaryTerms, type GlossarySummary } from '@/lib/sanity';
import { generateDefinedTermSetSchema, generateBreadcrumb } from '@/lib/schema';
import { capFirst } from '@/lib/strings';

const terms = await getAllGlossaryTerms();

const CATEGORY_LABELS_PL: Record<GlossarySummary['category'], string> = {
  anatomy: 'Anatomia',
  condition: 'Schorzenie',
  procedure: 'Zabieg',
  investigation: 'Badanie',
  treatment: 'Leczenie',
  outcome: 'Miara wyniku',
  structure: 'Struktura anatomiczna',
  other: 'Słowniczek',
};

// Display name picks termPolish when present, otherwise falls back to the
// English term. Sort and grouping then use that resolved display name so the
// Polish alphabet (Ł, Ó, Ś, …) groups correctly.
function displayName(t: GlossarySummary): string {
  return t.termPolish?.trim() ? t.termPolish : t.term;
}

const collator = new Intl.Collator('pl', { sensitivity: 'base' });
const sorted = [...terms].sort((a, b) =>
  collator.compare(displayName(a), displayName(b)),
);

const groupMap = new Map<string, GlossarySummary[]>();
for (const term of sorted) {
  const letter = displayName(term).charAt(0).toUpperCase() || '#';
  const list = groupMap.get(letter) ?? [];
  list.push(term);
  groupMap.set(letter, list);
}
const grouped = Array.from(groupMap.entries()).map(([letter, items]) => ({
  letter,
  items,
}));
const letters = grouped.map((g) => g.letter);

const totalCount = terms.length;

const siteUrl = (
  import.meta.env.PUBLIC_SITE_URL || 'https://drgladysz.com'
).replace(/\/$/, '');
const canonicalUrl = `${siteUrl}/pl/slowniczek/`;

const definedTermSetJsonLd = generateDefinedTermSetSchema({
  url: canonicalUrl,
  name: 'Słowniczek chirurgii ręki — Mateusz Gładysz, MD',
  description:
    'Definicje struktur anatomicznych, schorzeń, zabiegów, badań i miar wyników z zakresu chirurgii ręki i rekonstrukcyjnej.',
  inLanguage: 'pl-PL',
  terms,
  termUrlPrefix: `${siteUrl}/pl/slowniczek/`,
  locale: 'pl',
});

const breadcrumbJsonLd = generateBreadcrumb([
  { name: 'Strona główna', url: `${siteUrl}/pl/` },
  { name: 'Słowniczek', url: canonicalUrl },
]);
---
<SiteLayout
  title="Słowniczek — Mateusz Gładysz, MD"
  description="Słowniczek terminów z zakresu chirurgii ręki i rekonstrukcyjnej: struktury anatomiczne, schorzenia, zabiegi, badania i miary wyników opracowane w kontekście klinicznym."
  locale="pl"
  alternateUrl="/en/glossary/"
  canonical={canonicalUrl}
  jsonLd={[definedTermSetJsonLd, breadcrumbJsonLd]}
>
  <section class="index-masthead-shell">
    <SectionMasthead
      label="Słowniczek"
      heading="Terminy chirurgii ręki — definicje"
      headingTag="h1"
      standfirst="Bieżące źródło definicji struktur anatomicznych, schorzeń, zabiegów, badań i miar wyników, które powtarzają się na łamach artykułów i opisów zabiegów na tej stronie. Każde hasło jest opracowane w przystępnym języku, z odsyłaczami do kontekstu klinicznego."
    />
    {totalCount > 0 && (
      <nav class="letter-nav" aria-label="Przejdź do litery">
        <ul>
          {letters.map((letter) => (
            <li>
              <a href={`#letter-${letter}`}>{letter}</a>
            </li>
          ))}
        </ul>
      </nav>
    )}
  </section>

  <section class="glossary-index">
    <div class="glossary-index-inner">
      {totalCount === 0 ? (
        <div class="empty">
          <p>Słowniczek jest w przygotowaniu. Zapraszamy wkrótce.</p>
        </div>
      ) : (
        grouped.map((group) => (
          <section
            class="letter-section"
            id={`letter-${group.letter}`}
            aria-labelledby={`letter-h-${group.letter}`}
          >
            <h2 id={`letter-h-${group.letter}`} class="letter-heading">
              {group.letter}
            </h2>
            <ol class="term-list">
              {group.items.map((term) => {
                const usingPolish = Boolean(term.termPolish?.trim());
                const displayedDef = term.shortDefinitionPolish?.trim()
                  ? term.shortDefinitionPolish
                  : term.shortDefinition;
                return (
                  <li class="term-card">
                    <a
                      href={`/pl/slowniczek/${term.slug.current}`}
                      class="term-card-link"
                    >
                      <p class="card-meta">
                        <span class="card-cat">
                          {CATEGORY_LABELS_PL[term.category]}
                        </span>
                        {!usingPolish && (
                          <span class="card-fallback" lang="en">EN</span>
                        )}
                      </p>
                      <h3
                        class="card-term"
                        lang={usingPolish ? 'pl' : 'en'}
                      >
                        {capFirst(usingPolish ? term.termPolish : term.term)}
                      </h3>
                      <p
                        class="card-def"
                        lang={term.shortDefinitionPolish?.trim() ? 'pl' : 'en'}
                      >
                        {displayedDef}
                      </p>
                    </a>
                  </li>
                );
              })}
            </ol>
          </section>
        ))
      )}
    </div>
  </section>
</SiteLayout>

<style>
  .index-masthead-shell {
    padding: clamp(56px, 8vw, 120px) clamp(20px, 5vw, 80px) 0;
    max-width: 1320px;
    margin: 0 auto;
  }

  .letter-nav {
    margin-top: 40px;
    padding: 16px 0;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    position: sticky;
    top: 0;
    z-index: 10;
    background: var(--bg);
  }

  .letter-nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 4px 14px;
  }

  .letter-nav a {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: var(--ink-2);
    text-decoration: none;
    padding: 4px 6px;
    border-bottom: 1px solid transparent;
    transition: color 0.15s ease, border-color 0.15s ease;
  }

  .letter-nav a:hover,
  .letter-nav a:focus-visible {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }

  .letter-nav a:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: 1px;
  }

  .glossary-index {
    padding: clamp(40px, 6vw, 80px) 0 120px;
  }

  .glossary-index-inner {
    max-width: 1320px;
    margin: 0 auto;
    padding-inline: clamp(20px, 5vw, 80px);
  }

  .empty {
    max-width: 60ch;
    font-family: var(--serif);
    font-style: italic;
    font-size: 18px;
    color: var(--ink-2);
  }

  .letter-section {
    margin-bottom: clamp(56px, 8vw, 96px);
    scroll-margin-top: 80px;
  }

  .letter-heading {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(56px, 8vw, 96px);
    line-height: 1;
    color: var(--accent);
    margin: 0 0 32px;
    letter-spacing: -0.03em;
    border-bottom: 1px solid var(--rule);
    padding-bottom: 16px;
  }

  .term-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 32px;
    grid-template-columns: 1fr;
  }

  @media (min-width: 700px) {
    .term-list {
      grid-template-columns: 1fr 1fr;
      column-gap: 48px;
    }
  }

  .term-card {
    border-top: 1px solid var(--rule);
    padding-top: 20px;
  }

  .term-card-link {
    display: grid;
    gap: 8px;
    text-decoration: none;
    color: inherit;
  }

  .term-card-link:hover .card-term {
    color: var(--accent);
  }

  .term-card-link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 6px;
  }

  .card-meta {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.10em;
    color: var(--ink-3);
    margin: 0;
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    align-items: baseline;
  }

  .card-cat {
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  /* Marker for terms whose Polish translation is not yet authored — the
     card still renders the English term so the link doesn't go cold. */
  .card-fallback {
    font-family: var(--mono);
    font-size: 9px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-3);
    border: 1px solid var(--rule-strong);
    padding: 1px 5px;
    border-radius: 2px;
  }

  .card-term {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(20px, 2vw, 24px);
    line-height: 1.2;
    color: var(--ink);
    margin: 0;
    letter-spacing: -0.012em;
    transition: color 0.15s ease;
  }

  .card-def {
    font-family: var(--serif);
    font-size: 16px;
    line-height: 1.55;
    color: var(--ink-2);
    margin: 0;
    max-width: 60ch;
  }
</style>
