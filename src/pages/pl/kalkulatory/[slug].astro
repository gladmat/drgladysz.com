---
// src/pages/pl/kalkulatory/[slug].astro
//
// Polish counterpart of /en/calculators/[slug]. Renders only locale='pl'
// calculator docs. Section labels are in Polish; the interactive widget
// itself is locale-aware (each calculator component receives `locale="pl"`
// and adapts question wording where a Polish translation has been plugged
// in — currently QuickDASH shows English questions with a notice).
import SiteLayout from '@/layouts/SiteLayout.astro';
import PortableTextRenderer from '@/components/content/PortableTextRenderer.astro';
import Bibliography from '@/components/content/Bibliography.astro';
import { calculatorRegistry } from '@/components/interactive/registry';
import {
  getAllCalculatorSlugsForLocale,
  getCalculatorBySlug,
  getReferencesByIds,
  getGlossaryTermsByIds,
  extractCitationOrderFromBlocks,
  extractGlossaryOrderFromBlocks,
} from '@/lib/sanity';
import { generateBreadcrumb } from '@/lib/schema';

export async function getStaticPaths() {
  const slugs = await getAllCalculatorSlugsForLocale('pl');
  return slugs.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
if (!slug) throw new Error('Missing slug param');

const calc = await getCalculatorBySlug(slug, 'pl');
if (!calc) {
  return Astro.redirect('/pl/kalkulatory/');
}

const allBlocks = [
  calc.whenToUse,
  calc.pearlsPitfalls,
  calc.whyUse,
  calc.nextSteps,
  calc.evidence,
  calc.creatorInsights,
];

const citationOrder = extractCitationOrderFromBlocks(allBlocks);
const referencesUnsorted = await getReferencesByIds(citationOrder);
const references = citationOrder
  .map((id) => referencesUnsorted.find((r) => r._id === id))
  .filter((r): r is NonNullable<typeof r> => Boolean(r));

const glossaryOrder = extractGlossaryOrderFromBlocks(allBlocks);
const glossaryTerms = await getGlossaryTermsByIds(glossaryOrder);

const Component = calculatorRegistry[calc.componentName];

const siteUrl = (
  import.meta.env.PUBLIC_SITE_URL || 'https://drgladysz.com'
).replace(/\/$/, '');
const canonicalUrl = `${siteUrl}/pl/kalkulatory/${slug}/`;

// PL→EN slug map for hreflang. Calculator slugs are currently identical
// across locales (separate-doc-per-locale schema with shared slug). Add an
// entry here only if a future PL calculator is published with a slug that
// differs from its EN counterpart.
const PL_TO_EN_SLUG: Record<string, string> = {
  // 'polski-slug': 'english-slug',
};
const enSlug = PL_TO_EN_SLUG[slug] ?? slug;

const calculatorJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: calc.name,
  alternateName: calc.fullName,
  url: canonicalUrl,
  description: calc.shortDescription,
  applicationCategory: 'MedicalApplication',
  operatingSystem: 'Any (web)',
  inLanguage: 'pl-PL',
  ...(references.length > 0
    ? {
        citation: references.map((r) => ({
          '@type': 'ScholarlyArticle',
          name: r.title,
          author: r.authors.map((a) => ({ '@type': 'Person', name: a })),
          datePublished: String(r.year),
          isPartOf: r.journal
            ? { '@type': 'Periodical', name: r.journal }
            : undefined,
          ...(r.doi ? { sameAs: `https://doi.org/${r.doi}` } : {}),
        })),
      }
    : {}),
};

const breadcrumbJsonLd = generateBreadcrumb([
  { name: 'Strona główna', url: `${siteUrl}/pl/` },
  { name: 'Kalkulatory', url: `${siteUrl}/pl/kalkulatory/` },
  { name: calc.name, url: canonicalUrl },
]);

const pageTitle = calc.seoTitle || `${calc.name} — Kalkulator — Mateusz Gładysz, MD`;
const pageDescription = calc.seoDescription || calc.shortDescription;
---
<SiteLayout
  title={pageTitle}
  description={pageDescription}
  locale="pl"
  alternateUrl={`/en/calculators/${enSlug}/`}
  canonical={canonicalUrl}
  jsonLd={[calculatorJsonLd, breadcrumbJsonLd]}
>
  <article class="calc-shell">
    <header class="calc-header">
      <p class="calc-kicker">
        <a href="/pl/kalkulatory/">Kalkulatory</a>
        <span aria-hidden="true">·</span>
        <span>{calc.componentName}</span>
      </p>
      <p class="calc-fullname">{calc.fullName}</p>
      <h1 class="calc-name">{calc.name}</h1>
      <p class="calc-description">{calc.shortDescription}</p>
    </header>

    <section class="calc-widget-section" aria-labelledby="widget-heading">
      <h2 id="widget-heading" class="calc-section-heading">Kalkulator</h2>
      {Component ? (
        <Component client:load locale="pl" />
      ) : (
        <div class="calc-placeholder">
          <p class="calc-placeholder-label">Kalkulator w przygotowaniu</p>
          <p class="calc-placeholder-body">
            Interaktywny kalkulator jest w trakcie budowy. Treść redakcyjna
            poniżej.
          </p>
        </div>
      )}
    </section>

    <div class="calc-content">
      <section class="calc-section" aria-labelledby="when-heading">
        <h2 id="when-heading" class="calc-section-heading">Kiedy stosować</h2>
        <PortableTextRenderer
          value={calc.whenToUse}
          references={references}
          glossaryTerms={glossaryTerms}
        />
      </section>

      {calc.pearlsPitfalls && calc.pearlsPitfalls.length > 0 && (
        <section class="calc-section" aria-labelledby="pearls-heading">
          <h2 id="pearls-heading" class="calc-section-heading">
            Wskazówki i ograniczenia
          </h2>
          <PortableTextRenderer
            value={calc.pearlsPitfalls}
            references={references}
            glossaryTerms={glossaryTerms}
          />
        </section>
      )}

      <section class="calc-section" aria-labelledby="why-heading">
        <h2 id="why-heading" class="calc-section-heading">Dlaczego stosować</h2>
        <PortableTextRenderer
          value={calc.whyUse}
          references={references}
          glossaryTerms={glossaryTerms}
        />
      </section>

      {calc.nextSteps && calc.nextSteps.length > 0 && (
        <section class="calc-section" aria-labelledby="next-heading">
          <h2 id="next-heading" class="calc-section-heading">
            Następne kroki w zależności od wyniku
          </h2>
          <PortableTextRenderer
            value={calc.nextSteps}
            references={references}
            glossaryTerms={glossaryTerms}
          />
        </section>
      )}

      <section class="calc-section" aria-labelledby="evidence-heading">
        <h2 id="evidence-heading" class="calc-section-heading">Dowody naukowe</h2>
        <PortableTextRenderer
          value={calc.evidence}
          references={references}
          glossaryTerms={glossaryTerms}
        />
      </section>

      {calc.creatorInsights && calc.creatorInsights.length > 0 && (
        <section class="calc-section" aria-labelledby="insights-heading">
          <h2 id="insights-heading" class="calc-section-heading">
            Uwagi autora
          </h2>
          <PortableTextRenderer
            value={calc.creatorInsights}
            references={references}
            glossaryTerms={glossaryTerms}
          />
        </section>
      )}

      <Bibliography references={references} />
    </div>
  </article>
</SiteLayout>

<style>
  .calc-shell {
    max-width: 1320px;
    margin: 0 auto;
    padding: clamp(40px, 7vw, 96px) clamp(20px, 5vw, 80px) 120px;
  }

  .calc-header {
    margin-bottom: clamp(40px, 6vw, 64px);
    max-width: 760px;
  }

  .calc-kicker {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin: 0 0 24px;
    display: flex;
    gap: 12px;
    align-items: center;
    flex-wrap: wrap;
  }

  .calc-kicker a {
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid var(--accent);
    padding-bottom: 1px;
  }

  .calc-kicker a:hover {
    color: var(--ink);
    border-bottom-color: var(--ink);
  }

  .calc-fullname {
    font-family: var(--serif);
    font-style: italic;
    font-size: clamp(15px, 1.4vw, 18px);
    line-height: 1.5;
    color: var(--ink-2);
    margin: 0 0 8px;
  }

  .calc-name {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(34px, 5vw, 56px);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin: 0 0 16px;
  }

  .calc-description {
    font-family: var(--serif);
    font-style: italic;
    font-size: clamp(18px, 1.6vw, 22px);
    line-height: 1.55;
    color: var(--ink-2);
    margin: 0;
    max-width: 60ch;
  }

  .calc-widget-section {
    margin-bottom: clamp(48px, 7vw, 80px);
  }

  .calc-widget-section .calc-section-heading {
    position: absolute;
    width: 1px;
    height: 1px;
    margin: -1px;
    padding: 0;
    border: 0;
    clip: rect(0 0 0 0);
    overflow: hidden;
    white-space: nowrap;
  }

  .calc-section {
    margin-bottom: clamp(40px, 6vw, 64px);
    max-width: 720px;
  }

  .calc-section-heading {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 24px;
    padding-top: 32px;
    border-top: 1px solid var(--rule);
    font-weight: 500;
  }

  .calc-content {
    max-width: 1320px;
    margin: 0 auto;
    position: relative;
  }

  @media (min-width: 1024px) {
    .calc-content {
      padding-right: 320px;
      max-width: 1040px;
    }
  }

  .calc-placeholder {
    background: var(--bg-card);
    border: 1px solid var(--rule);
    padding: 32px;
    text-align: center;
  }

  .calc-placeholder-label {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 12px;
  }

  .calc-placeholder-body {
    font-family: var(--serif);
    font-style: italic;
    font-size: 16px;
    line-height: 1.55;
    color: var(--ink-2);
    margin: 0;
    max-width: 60ch;
    margin-inline: auto;
  }
</style>
