---
// src/pages/pl/kalkulatory/index.astro
//
// Polish counterpart of /en/calculators. Pulls only locale='pl' calculator
// docs (separate-doc-per-locale model). Polish chrome is a working draft —
// flag for revision in the Polish composition session.
import SiteLayout from '@/layouts/SiteLayout.astro';
import SectionMasthead from '@/components/SectionMasthead.astro';
import { getAllCalculatorSummaries } from '@/lib/sanity';
import { generateBreadcrumb } from '@/lib/schema';

const calculators = await getAllCalculatorSummaries('pl');

const totalCount = calculators.length;

const siteUrl = (
  import.meta.env.PUBLIC_SITE_URL || 'https://drgladysz.com'
).replace(/\/$/, '');
const canonicalUrl = `${siteUrl}/pl/kalkulatory/`;

const collectionJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Kalkulatory chirurgii ręki — Mateusz Gładysz, MD',
  url: canonicalUrl,
  inLanguage: 'pl-PL',
  description:
    'Natywne, walidowane skale wyników i nasilenia używane w chirurgii ręki i kończyny górnej: QuickDASH, PRWE, Boston CTS, MHQ oraz Mayo Wrist.',
  hasPart: calculators.map((c) => ({
    '@type': 'WebApplication',
    name: c.name,
    alternateName: c.fullName,
    url: `${siteUrl}/pl/kalkulatory/${c.slug.current}/`,
    description: c.shortDescription,
    applicationCategory: 'MedicalApplication',
  })),
};

const breadcrumbJsonLd = generateBreadcrumb([
  { name: 'Strona główna', url: `${siteUrl}/pl/` },
  { name: 'Kalkulatory', url: canonicalUrl },
]);
---
<SiteLayout
  title="Kalkulatory — Mateusz Gładysz, MD"
  description="Walidowane skale wyników w chirurgii ręki: QuickDASH, PRWE, Boston CTS, MHQ oraz Mayo Wrist."
  locale="pl"
  alternateUrl="/en/calculators/"
  canonical={canonicalUrl}
  jsonLd={[collectionJsonLd, breadcrumbJsonLd]}
>
  <section class="index-masthead-shell">
    <SectionMasthead
      label="Kalkulatory"
      heading="Kalkulatory wyników i nasilenia"
      headingTag="h1"
      standfirst="Natywne implementacje walidowanych skal wyników raportowanych przez pacjentów oraz klinicznych skal nasilenia stosowanych w chirurgii ręki i kończyny górnej. Każdy kalkulator zawiera wzór punktacji, wskazania do zastosowania oraz piśmiennictwo wspierające."
    />
  </section>

  <section class="calculator-index">
    <div class="calculator-index-inner">
      {totalCount === 0 ? (
        <div class="empty">
          <p>Pierwsze kalkulatory są w przygotowaniu. Zapraszamy wkrótce.</p>
        </div>
      ) : (
        <ol class="calculator-list">
          {calculators.map((c) => (
            <li class="calculator-card">
              <a
                href={`/pl/kalkulatory/${c.slug.current}`}
                class="calculator-card-link"
              >
                <p class="card-meta">
                  <span class="card-tag">Kalkulator</span>
                </p>
                <h2 class="card-name">{c.name}</h2>
                <p class="card-fullname">{c.fullName}</p>
                <p class="card-desc">{c.shortDescription}</p>
              </a>
            </li>
          ))}
        </ol>
      )}
    </div>
  </section>
</SiteLayout>

<style>
  .index-masthead-shell {
    padding: clamp(56px, 8vw, 120px) clamp(20px, 5vw, 80px) 0;
    max-width: 1320px;
    margin: 0 auto;
  }

  .calculator-index {
    padding: clamp(40px, 6vw, 80px) 0 120px;
  }

  .calculator-index-inner {
    max-width: 1320px;
    margin: 0 auto;
    padding-inline: clamp(20px, 5vw, 80px);
  }

  .empty {
    max-width: 60ch;
    font-family: var(--serif);
    font-style: italic;
    font-size: 18px;
    color: var(--ink-2);
  }

  .calculator-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 32px;
    grid-template-columns: 1fr;
  }

  @media (min-width: 700px) {
    .calculator-list {
      grid-template-columns: 1fr 1fr;
      column-gap: 48px;
    }
  }

  .calculator-card {
    border-top: 1px solid var(--rule);
    padding-top: 28px;
  }

  .calculator-card-link {
    display: grid;
    gap: 10px;
    text-decoration: none;
    color: inherit;
    max-width: 540px;
  }

  .calculator-card-link:hover .card-name {
    color: var(--accent);
  }

  .calculator-card-link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 6px;
  }

  .card-meta {
    margin: 0;
  }

  .card-tag {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .card-name {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(24px, 2.4vw, 32px);
    line-height: 1.15;
    color: var(--ink);
    margin: 0;
    letter-spacing: -0.018em;
    transition: color 0.15s ease;
  }

  .card-fullname {
    font-family: var(--serif);
    font-style: italic;
    font-size: 15px;
    line-height: 1.4;
    color: var(--ink-2);
    margin: 0;
  }

  .card-desc {
    font-family: var(--serif);
    font-size: 16px;
    line-height: 1.55;
    color: var(--ink-2);
    margin: 0;
    max-width: 60ch;
  }
</style>
