---
// src/pages/pl/zabiegi/[slug].astro
//
// Polish procedure detail page. Mirror of /en/procedures/[slug].astro,
// scoped to language == 'pl', with PL section labels and FAQ rendering.
//
// JSON-LD: MedicalProcedure + MedicalCondition + FAQPage + BreadcrumbList,
// all `inLanguage: 'pl-PL'`.
import SiteLayout from '@/layouts/SiteLayout.astro';
import KeyPoints from '@/components/content/KeyPoints.astro';
import Bibliography from '@/components/content/Bibliography.astro';
import PortableTextRenderer from '@/components/content/PortableTextRenderer.astro';
import {
  getAllProcedureSlugs,
  getProcedureBySlug,
  getReferencesByIds,
  extractCitationOrderFromBlocks,
  getGlossaryTermsByIds,
  extractGlossaryOrderFromBlocks,
  urlForImage,
} from '@/lib/sanity';
import {
  generateProcedureSchema,
  generateBreadcrumb,
  generateFaqPageSchema,
  generateMedicalConditionSchema,
} from '@/lib/schema';

export async function getStaticPaths() {
  const slugs = await getAllProcedureSlugs('pl');
  return slugs.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
if (!slug) throw new Error('Missing slug param');

const procedure = await getProcedureBySlug(slug, 'pl');
if (!procedure) {
  return Astro.redirect('/pl/zabiegi/');
}

// PL→EN slug map for hreflang. Update this when adding new PL procedures.
const PL_TO_EN_SLUG: Record<string, string> = {
  'zespol-ciesni-nadgarstka': 'open-carpal-tunnel-release',
};
const enSlug = PL_TO_EN_SLUG[slug];
const alternateUrl = enSlug ? `/en/procedures/${enSlug}/` : undefined;

// MedicalCondition pairing — currently only one PL procedure (CTS) but
// authored as a slug-keyed map so future procedures (Dupuytren, trigger
// finger, de Quervain, ganglion) can each declare their own condition.
//
// Values per the locked SEO spec for this procedure (PL CTS package
// `drgladysz-seo-and-schema-procedure-cts-pl-v1_1.md` §2.2). ICD-10 G56.0.
type MedicalConditionMeta = Parameters<typeof generateMedicalConditionSchema>[0];
const CONDITION_BY_PROCEDURE: Record<string, Omit<MedicalConditionMeta, 'url' | 'locale'>> = {
  'zespol-ciesni-nadgarstka': {
    name: 'Zespół cieśni nadgarstka',
    alternateName: ['ZCN', 'Zespół kanału nadgarstka', 'ZKN'],
    description:
      'Najczęstsza neuropatia uciskowa kończyny górnej; ucisk nerwu pośrodkowego w obrębie kanału nadgarstka powodujący drętwienia, parestezje i ból w obszarze unerwienia nerwu pośrodkowego.',
    icd10: 'G56.0',
    signOrSymptom: [
      'Drętwienia i parestezje w obszarze unerwienia nerwu pośrodkowego',
      'Nocne dolegliwości',
      'Osłabienie i zanik mięśni kłębu kciuka',
      'Ból w okolicy nadgarstka i przedramienia',
    ],
    possibleTreatment: [
      'Otwarte odbarczenie kanału nadgarstka',
      'Endoskopowe odbarczenie kanału nadgarstka',
      'Iniekcja glikokortykosteroidu',
      'Orteza unieruchamiająca nadgarstek',
    ],
    differentialDiagnosis: [
      'Radikulopatia szyjna C6/C7',
      'Neuropatia nerwu łokciowego',
      'Neuropatia obwodowa (cukrzycowa, alkoholowa)',
      'Zespół ujścia górnego klatki piersiowej',
    ],
    epidemiology: '~3–5% populacji ogólnej; częściej kobiety, szczyt zachorowalności 40–60 r.ż.',
    relevantSpecialty: ['Hand surgery', 'Plastic surgery', 'Orthopaedic surgery', 'Neurology'],
  },
};

const stepDescriptions = procedure.keySteps.map((s) => s.description).flat();

const citationOrder = extractCitationOrderFromBlocks([
  procedure.indications,
  procedure.contraindications,
  procedure.anatomy,
  procedure.positioning,
  procedure.approach,
  stepDescriptions,
  procedure.closure,
  procedure.aftercare,
  procedure.complications,
  procedure.patientSummary,
  procedure.evidence,
]);

const referencesUnsorted = await getReferencesByIds(citationOrder);
const references = citationOrder
  .map((id) => referencesUnsorted.find((r) => r._id === id))
  .filter((r): r is NonNullable<typeof r> => Boolean(r));

const glossaryOrder = extractGlossaryOrderFromBlocks([
  procedure.indications,
  procedure.contraindications,
  procedure.anatomy,
  procedure.positioning,
  procedure.approach,
  stepDescriptions,
  procedure.closure,
  procedure.aftercare,
  procedure.complications,
  procedure.patientSummary,
  procedure.evidence,
]);
const glossaryTerms = await getGlossaryTermsByIds(glossaryOrder);

const siteUrl = (
  import.meta.env.PUBLIC_SITE_URL || 'https://drgladysz.com'
).replace(/\/$/, '');
const canonicalUrl = `${siteUrl}/pl/zabiegi/${slug}/`;

const procedureHeroImageData = procedure.heroImage
  ? {
      url: urlForImage(procedure.heroImage).width(1200).height(800).fit('crop').url(),
      width: 1200,
      height: 800,
      alt: procedure.heroImage.alt,
    }
  : undefined;

const procedureJsonLd = generateProcedureSchema({
  procedure,
  references,
  url: canonicalUrl,
  heroImage: procedureHeroImageData,
  locale: 'pl',
});

const categoryLabels: Record<string, string> = {
  'hand-surgery': 'Chirurgia ręki',
  'reconstructive-microsurgery': 'Mikrochirurgia rekonstrukcyjna',
  'skin-cancer': 'Chirurgia nowotworów skóry',
};

const breadcrumbJsonLd = generateBreadcrumb([
  { name: 'Strona główna', url: `${siteUrl}/pl/` },
  { name: 'Zabiegi', url: `${siteUrl}/pl/zabiegi/` },
  {
    name: categoryLabels[procedure.category] || procedure.category,
    url: `${siteUrl}/pl/zabiegi/#${procedure.category}`,
  },
  { name: procedure.title, url: canonicalUrl },
]);

const conditionMeta = CONDITION_BY_PROCEDURE[slug];
const conditionJsonLd = conditionMeta
  ? generateMedicalConditionSchema({
      url: canonicalUrl,
      locale: 'pl',
      ...conditionMeta,
    })
  : undefined;

const faqJsonLd =
  procedure.faq && procedure.faq.length > 0
    ? generateFaqPageSchema(procedure.faq, canonicalUrl, 'pl')
    : undefined;

// Compose the JSON-LD array from defined entries only.
const jsonLdBlocks = [
  procedureJsonLd,
  breadcrumbJsonLd,
  ...(conditionJsonLd ? [conditionJsonLd] : []),
  ...(faqJsonLd ? [faqJsonLd] : []),
];

const lastUpdatedLabel = new Date(procedure.lastUpdated).toLocaleDateString(
  'pl-PL',
  { year: 'numeric', month: 'long', day: 'numeric' },
);

const heroImageUrl = procedure.heroImage
  ? urlForImage(procedure.heroImage).width(2000).fit('max').url()
  : null;

const hasContraindications =
  procedure.contraindications && procedure.contraindications.length > 0;
const hasPositioning =
  procedure.positioning && procedure.positioning.length > 0;
const hasClosure = procedure.closure && procedure.closure.length > 0;
const hasPatientSummary =
  procedure.patientSummary && procedure.patientSummary.length > 0;
const hasFaq = procedure.faq && procedure.faq.length > 0;

const relatedArticles = (procedure.relatedArticles ?? []).filter(
  (a): a is NonNullable<typeof a> => Boolean(a),
);
const relatedProcedures = (procedure.relatedProcedures ?? []).filter(
  (p): p is NonNullable<typeof p> => Boolean(p),
);
const hasRelated = relatedArticles.length > 0 || relatedProcedures.length > 0;

const articleCategoryLabel: Record<string, string> = {
  patient: 'Informacje dla pacjenta',
  expert: 'Artykuł ekspercki',
  'fessh-prep': 'FESSH preparation',
  news: 'Aktualności',
};
---
<SiteLayout
  title={procedure.seoTitle || `${procedure.title} — Mateusz Gładysz, lek.`}
  description={procedure.seoDescription || procedure.summary}
  locale="pl"
  alternateUrl={alternateUrl}
  canonical={canonicalUrl}
  jsonLd={jsonLdBlocks}
>
  <article class="procedure-shell">
    <header class="procedure-header">
      <p class="procedure-kicker">
        <a href="/pl/zabiegi/">Zabiegi</a>
        <span aria-hidden="true">·</span>
        <span>{categoryLabels[procedure.category] ?? procedure.category}</span>
      </p>
      <h1 class="procedure-title">{procedure.title}</h1>
      {procedure.summary && (
        <p class="procedure-summary">{procedure.summary}</p>
      )}
      <p class="procedure-meta">
        Ostatnia weryfikacja medyczna
        <time datetime={procedure.lastUpdated}>{lastUpdatedLabel}</time>
      </p>
    </header>

    {heroImageUrl && (
      <figure class="procedure-hero">
        <img
          src={heroImageUrl}
          alt={procedure.heroImage?.alt ?? ''}
          loading="eager"
          decoding="async"
        />
        {procedure.heroImage?.caption && (
          <figcaption>{procedure.heroImage.caption}</figcaption>
        )}
      </figure>
    )}

    <div class="article-content">
      {procedure.keyPoints && (
        <KeyPoints
          question={procedure.keyPoints.question}
          findings={procedure.keyPoints.findings}
          meaning={procedure.keyPoints.meaning}
          findingsLabel="Wskazania i przebieg"
          meaningLabel="Znaczenie kliniczne"
        />
      )}

      <nav class="procedure-toc" aria-label="Sekcje strony zabiegowej">
        <p class="toc-label">Spis treści</p>
        <ol>
          <li><a href="#indications">Wskazania</a></li>
          {hasContraindications && (
            <li><a href="#contraindications">Przeciwwskazania</a></li>
          )}
          <li><a href="#anatomy">Anatomia</a></li>
          {hasPositioning && (
            <li><a href="#positioning">Pozycjonowanie pacjenta</a></li>
          )}
          <li><a href="#approach">Dostęp operacyjny</a></li>
          <li><a href="#key-steps">Etapy kluczowe</a></li>
          {hasClosure && <li><a href="#closure">Zamknięcie</a></li>}
          <li><a href="#aftercare">Postępowanie pooperacyjne</a></li>
          <li><a href="#complications">Powikłania</a></li>
          <li><a href="#evidence">Dowody i piśmiennictwo</a></li>
          {hasFaq && <li><a href="#faq">FAQ</a></li>}
        </ol>
      </nav>

      <section id="indications" class="proc-section" aria-labelledby="h-indications">
        <h2 id="h-indications" class="proc-h"><span class="proc-num">1.</span> Wskazania</h2>
        <PortableTextRenderer value={procedure.indications} references={references} glossaryTerms={glossaryTerms} />
      </section>

      {hasContraindications && (
        <section id="contraindications" class="proc-section" aria-labelledby="h-contraind">
          <h2 id="h-contraind" class="proc-h"><span class="proc-num">2.</span> Przeciwwskazania</h2>
          <PortableTextRenderer value={procedure.contraindications} references={references} glossaryTerms={glossaryTerms} />
        </section>
      )}

      <section id="anatomy" class="proc-section" aria-labelledby="h-anatomy">
        <h2 id="h-anatomy" class="proc-h"><span class="proc-num">3.</span> Anatomia</h2>
        <PortableTextRenderer value={procedure.anatomy} references={references} glossaryTerms={glossaryTerms} />
      </section>

      {hasPositioning && (
        <section id="positioning" class="proc-section" aria-labelledby="h-pos">
          <h2 id="h-pos" class="proc-h"><span class="proc-num">4.</span> Pozycjonowanie pacjenta</h2>
          <PortableTextRenderer value={procedure.positioning} references={references} glossaryTerms={glossaryTerms} />
        </section>
      )}

      <section id="approach" class="proc-section" aria-labelledby="h-approach">
        <h2 id="h-approach" class="proc-h"><span class="proc-num">5.</span> Dostęp operacyjny</h2>
        <PortableTextRenderer value={procedure.approach} references={references} glossaryTerms={glossaryTerms} />
      </section>

      <section id="key-steps" class="proc-section proc-steps" aria-labelledby="h-steps">
        <h2 id="h-steps" class="proc-h"><span class="proc-num">6.</span> Etapy kluczowe</h2>
        <ol class="steps-list">
          {procedure.keySteps.map((step, i) => (
            <li id={`step-${i + 1}`} class="step">
              <h3 class="step-h">
                <span class="step-num">{i + 1}.</span>
                {step.title}
              </h3>
              <PortableTextRenderer value={step.description} references={references} glossaryTerms={glossaryTerms} />
              {step.image && step.image.asset && (
                <figure class="step-figure">
                  <img
                    src={urlForImage(step.image).width(1200).fit('max').url()}
                    srcset={[800, 1200, 1600]
                      .map((w) => `${urlForImage(step.image!).width(w).fit('max').url()} ${w}w`)
                      .join(', ')}
                    sizes="(max-width: 720px) 100vw, 720px"
                    alt={step.image.alt}
                    loading="lazy"
                    decoding="async"
                  />
                  {step.image.caption && (
                    <figcaption>{step.image.caption}</figcaption>
                  )}
                </figure>
              )}
              {step.pitfall && (
                <aside class="pitfall" role="note">
                  <p class="pitfall-label">Uwaga techniczna</p>
                  <p class="pitfall-body">{step.pitfall}</p>
                </aside>
              )}
            </li>
          ))}
        </ol>
      </section>

      {hasClosure && (
        <section id="closure" class="proc-section" aria-labelledby="h-closure">
          <h2 id="h-closure" class="proc-h"><span class="proc-num">7.</span> Zamknięcie</h2>
          <PortableTextRenderer value={procedure.closure} references={references} glossaryTerms={glossaryTerms} />
        </section>
      )}

      <section id="aftercare" class="proc-section" aria-labelledby="h-aftercare">
        <h2 id="h-aftercare" class="proc-h"><span class="proc-num">8.</span> Postępowanie pooperacyjne</h2>
        <PortableTextRenderer value={procedure.aftercare} references={references} glossaryTerms={glossaryTerms} />
      </section>

      <section id="complications" class="proc-section" aria-labelledby="h-comp">
        <h2 id="h-comp" class="proc-h"><span class="proc-num">9.</span> Powikłania</h2>
        <PortableTextRenderer value={procedure.complications} references={references} glossaryTerms={glossaryTerms} />
      </section>

      <section id="evidence" class="proc-section" aria-labelledby="h-evidence">
        <h2 id="h-evidence" class="proc-h"><span class="proc-num">10.</span> Dowody i piśmiennictwo</h2>
        <PortableTextRenderer value={procedure.evidence} references={references} glossaryTerms={glossaryTerms} />
      </section>

      {hasPatientSummary && (
        <details class="patient-summary">
          <summary>Dla pacjentów — informacje w przystępnym języku</summary>
          <div class="patient-summary-body">
            <PortableTextRenderer
              value={procedure.patientSummary}
              references={references}
              glossaryTerms={glossaryTerms}
            />
          </div>
        </details>
      )}

      {hasFaq && (
        <section id="faq" class="proc-faq" aria-labelledby="h-faq">
          <h2 id="h-faq" class="proc-h"><span class="proc-num">FAQ</span> Najczęstsze pytania</h2>
          <div class="faq-list">
            {procedure.faq!.map((item, i) => (
              <details class="faq-item" name="cts-faq" open={i === 0 ? true : undefined}>
                <summary>{item.question}</summary>
                <div class="faq-answer">
                  <PortableTextRenderer
                    value={item.answer}
                    references={references}
                    glossaryTerms={glossaryTerms}
                  />
                </div>
              </details>
            ))}
          </div>
        </section>
      )}

      <Bibliography references={references} />

      {hasRelated && (
        <aside class="proc-related" aria-labelledby="related-heading">
          <h2 id="related-heading" class="related-heading">Powiązane</h2>
          {relatedArticles.length > 0 && (
            <section class="related-section">
              <p class="related-kicker">Artykuły</p>
              <ul class="related-list">
                {relatedArticles.map((a) => (
                  <li>
                    <a href={`/pl/blog/${a.slug.current}/`}>
                      <span class="related-title">{a.title}</span>
                      <span class="related-meta">{articleCategoryLabel[a.category] ?? a.category}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          )}
          {relatedProcedures.length > 0 && (
            <section class="related-section">
              <p class="related-kicker">Zabiegi</p>
              <ul class="related-list">
                {relatedProcedures.map((p) => (
                  <li>
                    <a href={`/pl/zabiegi/${p.slug.current}/`}>
                      <span class="related-title">{p.title}</span>
                      <span class="related-meta">{categoryLabels[p.category] ?? p.category}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          )}
        </aside>
      )}
    </div>
  </article>
</SiteLayout>

<style>
  .procedure-shell {
    max-width: 1320px;
    margin: 0 auto;
    padding: clamp(40px, 7vw, 96px) clamp(20px, 5vw, 80px) 120px;
  }

  .procedure-header {
    margin-bottom: clamp(40px, 6vw, 72px);
    max-width: 760px;
  }

  .procedure-kicker {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin: 0 0 24px;
    display: flex;
    gap: 12px;
    align-items: center;
  }

  .procedure-kicker a {
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid var(--accent);
    padding-bottom: 1px;
  }

  .procedure-title {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(34px, 5vw, 52px);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin: 0 0 20px;
  }

  .procedure-summary {
    font-family: var(--serif);
    font-style: italic;
    font-size: clamp(17px, 1.5vw, 20px);
    line-height: 1.55;
    color: var(--ink-2);
    margin: 0 0 24px;
    max-width: 60ch;
  }

  .procedure-meta {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.06em;
    color: var(--ink-3);
    margin: 0;
  }

  .procedure-hero { margin: 0 0 64px; }
  .procedure-hero img {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 16/9;
    object-fit: cover;
  }
  .procedure-hero figcaption {
    font-family: var(--sans);
    font-size: 13px;
    color: var(--ink-3);
    line-height: 1.55;
    margin-top: 12px;
    font-style: italic;
  }

  .article-content {
    max-width: 720px;
    margin: 0;
    position: relative;
  }
  @media (min-width: 1024px) {
    .article-content {
      padding-right: 320px;
      max-width: 1040px;
    }
  }

  .procedure-toc {
    margin: 0 0 64px;
    padding: 24px 28px;
    background: var(--bg-deep);
    border-left: 3px solid var(--rule-strong);
  }
  .toc-label {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin: 0 0 16px;
  }
  .procedure-toc ol {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 8px 24px;
  }
  .procedure-toc a {
    font-family: var(--sans);
    font-size: 14px;
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px dotted var(--rule-strong);
    padding-bottom: 1px;
  }
  .procedure-toc a:hover {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }

  .proc-section {
    margin-bottom: 72px;
    scroll-margin-top: 96px;
  }
  .proc-section::after { content: ''; display: block; clear: both; }

  .proc-h {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(26px, 2.6vw, 36px);
    line-height: 1.2;
    color: var(--ink);
    margin: 0 0 28px;
    letter-spacing: -0.018em;
  }
  .proc-num {
    font-family: var(--mono);
    font-weight: 400;
    font-size: 0.7em;
    color: var(--accent);
    margin-right: 12px;
    letter-spacing: 0.04em;
  }

  .steps-list { list-style: none; padding: 0; margin: 0; }
  .step {
    margin-bottom: 64px;
    scroll-margin-top: 96px;
  }
  .step-h {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(20px, 1.8vw, 24px);
    line-height: 1.25;
    color: var(--ink);
    margin: 0 0 20px;
    letter-spacing: -0.012em;
  }
  .step-num {
    font-family: var(--mono);
    font-weight: 400;
    color: var(--accent);
    margin-right: 10px;
  }

  .step-figure { margin: 24px 0; }
  .step-figure img { width: 100%; height: auto; display: block; }
  .step-figure figcaption {
    font-family: var(--sans);
    font-size: 13px;
    color: var(--ink-3);
    line-height: 1.55;
    margin-top: 8px;
    font-style: italic;
  }

  .pitfall {
    margin-top: 24px;
    padding: 16px 20px 4px;
    background: var(--bg-deep);
    border-left: 3px solid var(--accent);
  }
  .pitfall-label {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 8px;
    font-weight: 500;
  }
  .pitfall-body {
    font-family: var(--sans);
    font-size: 15px;
    line-height: 1.65;
    color: var(--ink);
    margin: 0 0 12px;
    max-width: none;
  }

  .patient-summary {
    margin: 56px 0;
    padding: 24px 28px;
    background: var(--bg-deep);
    border-left: 3px solid var(--accent);
  }
  .patient-summary summary {
    font-family: var(--serif);
    font-weight: 500;
    font-size: 18px;
    color: var(--accent);
    cursor: pointer;
    list-style: none;
  }
  .patient-summary summary::-webkit-details-marker { display: none; }
  .patient-summary summary::before {
    content: '+ ';
    font-family: var(--mono);
    color: var(--accent);
    margin-right: 8px;
    font-weight: 400;
  }
  .patient-summary[open] summary::before { content: '− '; }
  .patient-summary[open] summary { margin-bottom: 16px; }
  .patient-summary-body { margin-top: 16px; }

  /* FAQ — collapsible Q/A blocks. The `name="cts-faq"` exclusive accordion
     pattern is opt-in: only one FAQ item open at a time per native HTML. */
  .proc-faq {
    margin-bottom: 72px;
    scroll-margin-top: 96px;
  }
  .faq-list {
    border-top: 1px solid var(--rule);
  }
  .faq-item {
    border-bottom: 1px solid var(--rule);
  }
  .faq-item summary {
    font-family: var(--serif);
    font-weight: 500;
    font-size: 19px;
    line-height: 1.35;
    color: var(--ink);
    cursor: pointer;
    list-style: none;
    padding: 20px 0;
    display: flex;
    align-items: baseline;
    gap: 14px;
