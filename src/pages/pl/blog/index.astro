---
// src/pages/pl/blog/index.astro
//
// Polish knowledge base index (Baza wiedzy). Lists PL articles grouped by
// category in fixed editorial order. Per Decision #34 / brand spec v1.10,
// PL has 3 categories (no fessh-prep — FESSH exam is English-language).
//
// Empty categories render an "in preparation" line so the page reads as a
// section index rather than collapsing to nothing while early articles ship.
import SiteLayout from '@/layouts/SiteLayout.astro';
import SectionMasthead from '@/components/SectionMasthead.astro';
import { getAllArticleSummaries, type ArticleSummary } from '@/lib/sanity';
import { generateBreadcrumb } from '@/lib/schema';

const siteUrl = (
  import.meta.env.PUBLIC_SITE_URL || 'https://drgladysz.com'
).replace(/\/$/, '');
const canonicalUrl = `${siteUrl}/pl/blog/`;

const articles = await getAllArticleSummaries('pl');

const CATEGORIES: {
  value: ArticleSummary['category'];
  label: string;
  blurb: string;
}[] = [
  {
    value: 'patient',
    label: 'Informacje dla pacjenta',
    blurb:
      'Przewodniki w przystępnym języku — opis schorzeń, przebieg diagnostyki oraz to, czego można się spodziewać po leczeniu.',
  },
  {
    value: 'expert',
    label: 'Artykuły eksperckie',
    blurb:
      'Technika operacyjna, przegląd dowodów i decyzje kliniczne — pisane z myślą o lekarzach.',
  },
  {
    value: 'news',
    label: 'Aktualności',
    blurb:
      'Notatki z konferencji, spotkań naukowych i bieżących wydarzeń w obszarze chirurgii ręki i mikrochirurgii rekonstrukcyjnej.',
  },
];

const grouped = CATEGORIES.map((c) => ({
  ...c,
  items: articles.filter((a) => a.category === c.value),
}));

const collectionJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Baza wiedzy — Mateusz Gładysz, lek.',
  url: canonicalUrl,
  inLanguage: 'pl-PL',
  hasPart: articles.map((a) => ({
    '@type': 'Article',
    headline: a.title,
    url: `${siteUrl}/pl/blog/${a.slug.current}/`,
    datePublished: a.publishedDate,
    description: a.excerpt,
  })),
};

const breadcrumbJsonLd = generateBreadcrumb([
  { name: 'Strona główna', url: `${siteUrl}/pl/` },
  { name: 'Baza wiedzy', url: canonicalUrl },
]);

function fmtDate(d?: string) {
  if (!d) return '';
  return new Date(d).toLocaleDateString('pl-PL', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}

const categoryLabels: Record<ArticleSummary['category'], string> = {
  patient: 'Informacje dla pacjenta',
  expert: 'Artykuł ekspercki',
  'fessh-prep': 'FESSH preparation',
  news: 'Aktualności',
};
---
<SiteLayout
  title="Baza wiedzy — Mateusz Gładysz, lek."
  description="Przewodniki dla pacjentów, teksty eksperckie z chirurgii ręki i mikrochirurgii rekonstrukcyjnej oraz notatki z konferencji."
  locale="pl"
  alternateUrl="/en/blog/"
  canonical={canonicalUrl}
  jsonLd={[collectionJsonLd, breadcrumbJsonLd]}
>
  <section class="index-masthead-shell">
    <SectionMasthead
      label="Baza wiedzy"
      heading="Artykuły, notatki techniczne i lektury"
      headingTag="h1"
      standfirst="Przewodniki dla pacjentów napisane w przystępnym języku obok eksperckich tekstów dla lekarzy — obejmują technikę operacyjną, ocenę dowodów oraz decyzje kliniczne w zakresie chirurgii ręki i mikrochirurgii rekonstrukcyjnej."
    />
  </section>

  <section class="blog-index">
    <div class="blog-index-inner">
      {grouped.map((cat) => (
        <section class="cat-section" aria-labelledby={`cat-${cat.value}`}>
          <header class="cat-header">
            <h2 id={`cat-${cat.value}`} class="cat-heading">{cat.label}</h2>
            <p class="cat-blurb">{cat.blurb}</p>
          </header>
          {cat.items.length > 0 ? (
            <ol class="article-list">
              {cat.items.map((article) => (
                <li class="article-card">
                  <a href={`/pl/blog/${article.slug.current}/`} class="article-card-link">
                    <p class="card-meta">
                      <span class="card-cat">{categoryLabels[article.category]}</span>
                      <span aria-hidden="true">·</span>
                      <time datetime={article.publishedDate}>
                        {fmtDate(article.publishedDate)}
                      </time>
                      {article.lastUpdated && article.lastUpdated !== article.publishedDate && (
                        <>
                          <span aria-hidden="true">·</span>
                          <span class="card-updated">
                            Aktualizacja {fmtDate(article.lastUpdated)}
                          </span>
                        </>
                      )}
                    </p>
                    <h3 class="card-title">{article.title}</h3>
                    <p class="card-excerpt">{article.excerpt}</p>
                  </a>
                </li>
              ))}
            </ol>
          ) : (
            <p class="empty">W przygotowaniu. Pierwsze artykuły w tej kategorii są w opracowaniu.</p>
          )}
        </section>
      ))}
    </div>
  </section>
</SiteLayout>

<style>
  .index-masthead-shell {
    padding: clamp(56px, 8vw, 120px) clamp(20px, 5vw, 80px) 0;
    max-width: 1320px;
    margin: 0 auto;
  }

  .blog-index {
    padding: clamp(40px, 6vw, 80px) 0 120px;
  }

  .blog-index-inner {
    max-width: 1320px;
    margin: 0 auto;
    padding-inline: clamp(20px, 5vw, 80px);
  }

  .cat-section {
    margin-bottom: clamp(56px, 8vw, 96px);
    padding-top: 32px;
    border-top: 1px solid var(--rule);
  }

  .cat-section:first-child {
    border-top: none;
    padding-top: 0;
  }

  .cat-header {
    max-width: 720px;
    margin-bottom: 40px;
  }

  .cat-heading {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(28px, 3vw, 40px);
    line-height: 1.15;
    color: var(--ink);
    margin: 0 0 12px;
    letter-spacing: -0.018em;
  }

  .cat-blurb {
    font-family: var(--serif);
    font-size: 17px;
    line-height: 1.55;
    color: var(--ink-2);
    margin: 0;
    max-width: 60ch;
  }

  .empty {
    font-family: var(--serif);
    font-style: italic;
    font-size: 16px;
    color: var(--ink-3);
    max-width: 60ch;
    margin: 0;
  }

  .article-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 32px;
  }

  .article-card {
    border-top: 1px solid var(--rule);
    padding-top: 28px;
  }

  .article-card-link {
    display: grid;
    gap: 12px;
    text-decoration: none;
    color: inherit;
    grid-template-columns: 1fr;
    max-width: 760px;
  }

  .article-card-link:hover .card-title {
    color: var(--accent);
  }

  .article-card-link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 6px;
  }

  .card-meta {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.06em;
    color: var(--ink-3);
    margin: 0;
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    align-items: baseline;
  }

  .card-cat {
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .card-updated {
    color: var(--ink-3);
  }

  .card-title {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(22px, 2.2vw, 28px);
    line-height: 1.2;
    color: var(--ink);
    margin: 0;
    letter-spacing: -0.012em;
    transition: color 0.15s ease;
  }

  .card-excerpt {
    font-family: var(--serif);
    font-size: 17px;
    line-height: 1.55;
    color: var(--ink-2);
    margin: 0;
    max-width: 60ch;
  }
</style>
