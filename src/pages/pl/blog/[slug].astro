---
// src/pages/pl/blog/[slug].astro
//
// Polish article detail page. Mirror of /en/blog/[slug].astro, scoped to
// language == 'pl'. Localizes all chrome strings (kicker, byline, meta,
// related, breadcrumb) into Polish and emits JSON-LD with `inLanguage: pl-PL`.
import SiteLayout from '@/layouts/SiteLayout.astro';
import KeyPoints from '@/components/content/KeyPoints.astro';
import Bibliography from '@/components/content/Bibliography.astro';
import PortableTextRenderer from '@/components/content/PortableTextRenderer.astro';
import {
  getAllArticleSlugs,
  getArticleBySlug,
  getReferencesByIds,
  getGlossaryTermsByIds,
  extractCitationOrderFromBlocks,
  extractGlossaryOrderFromBlocks,
  urlForImage,
} from '@/lib/sanity';
import { generateArticleSchema, generateBreadcrumb } from '@/lib/schema';

export async function getStaticPaths() {
  const slugs = await getAllArticleSlugs('pl');
  return slugs.map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
if (!slug) throw new Error('Missing slug param');

const article = await getArticleBySlug(slug, 'pl');
if (!article) {
  return Astro.redirect('/pl/blog/');
}

// PL→EN slug map for hreflang (alternateUrl). Authored explicitly so the
// reverse direction is obvious; falls back to none (no alternate emitted) for
// PL-only articles. Update this when adding new PL articles.
const PL_TO_EN_SLUG: Record<string, string> = {
  'zespol-ciesni-nadgarstka': 'carpal-tunnel-syndrome',
  'zespol-ciesni-nadgarstka-przeglad-kliniczny': 'carpal-tunnel-syndrome-fessh-prep',
};
const enSlug = PL_TO_EN_SLUG[slug];
const alternateUrl = enSlug ? `/en/blog/${enSlug}/` : undefined;

const citationOrder = extractCitationOrderFromBlocks([article.body]);
const referencesUnsorted = await getReferencesByIds(citationOrder);
const references = citationOrder
  .map((id) => referencesUnsorted.find((r) => r._id === id))
  .filter((r): r is NonNullable<typeof r> => Boolean(r));

const glossaryOrder = extractGlossaryOrderFromBlocks([article.body]);
const glossaryTerms = await getGlossaryTermsByIds(glossaryOrder);

const siteUrl = (
  import.meta.env.PUBLIC_SITE_URL || 'https://drgladysz.com'
).replace(/\/$/, '');
const canonicalUrl = `${siteUrl}/pl/blog/${slug}/`;

const articleHeroImageData = article.heroImage
  ? {
      url: urlForImage(article.heroImage).width(1200).height(800).fit('crop').url(),
      width: 1200,
      height: 800,
      alt: article.heroImage.alt,
    }
  : undefined;

const articleJsonLd = generateArticleSchema({
  article,
  references,
  url: canonicalUrl,
  heroImage: articleHeroImageData,
  locale: 'pl',
});

const breadcrumbJsonLd = generateBreadcrumb([
  { name: 'Strona główna', url: `${siteUrl}/pl/` },
  { name: 'Baza wiedzy', url: `${siteUrl}/pl/blog/` },
  { name: article.title, url: canonicalUrl },
]);

const publishedDateLabel = new Date(article.publishedDate).toLocaleDateString(
  'pl-PL',
  { year: 'numeric', month: 'long', day: 'numeric' },
);
const updatedDateLabel = article.lastUpdated
  ? new Date(article.lastUpdated).toLocaleDateString('pl-PL', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null;

const heroImageUrl = article.heroImage
  ? urlForImage(article.heroImage).width(2000).fit('max').url()
  : null;

const categoryLabel: Record<string, string> = {
  patient: 'Informacje dla pacjenta',
  expert: 'Artykuł ekspercki',
  'fessh-prep': 'FESSH preparation',
  news: 'Aktualności',
};

// Author byline — same defensive logic as EN (post-nominals may live in
// `credentials` or `title` field).
const POSTNOM_PATTERN = /^[A-Z][A-Za-z0-9]*$/;
function postNominalSegments(value: string | undefined): string[] {
  if (!value) return [];
  const parts = value.split(',').map((s) => s.trim()).filter(Boolean);
  return parts.every((p) => POSTNOM_PATTERN.test(p)) ? parts : [];
}
const authorPostNominals = article.author
  ? postNominalSegments(article.author.credentials).length > 0
    ? postNominalSegments(article.author.credentials)
    : postNominalSegments(article.author.title)
  : [];
// PL convention: prenominal `lek.` reserved for footer; byline drops MD per
// Decision #40. Trim 'MD' from post-nominals if present so the PL byline
// reads "Mateusz Gładysz · FEBOPRAS · FEBHS".
const plAuthorPostNominals = authorPostNominals.filter((p) => p !== 'MD');
const authorByline = article.author
  ? [article.author.name, ...plAuthorPostNominals].join(' · ')
  : null;

const standfirstText = article.standfirst?.trim() || article.excerpt;

const relatedArticles = (article.relatedArticles ?? []).filter(
  (a): a is NonNullable<typeof a> => Boolean(a),
);
const relatedProcedures = (article.relatedProcedures ?? []).filter(
  (p): p is NonNullable<typeof p> => Boolean(p),
);
const hasRelated = relatedArticles.length > 0 || relatedProcedures.length > 0;

const articleCategoryLabel: Record<string, string> = {
  patient: 'Informacje dla pacjenta',
  expert: 'Artykuł ekspercki',
  'fessh-prep': 'FESSH preparation',
  news: 'Aktualności',
};
const procedureCategoryLabel: Record<string, string> = {
  'hand-surgery': 'Chirurgia ręki',
  'reconstructive-microsurgery': 'Mikrochirurgia rekonstrukcyjna',
  'skin-cancer': 'Chirurgia nowotworów skóry',
};
---
<SiteLayout
  title={article.seoTitle || `${article.title} — Mateusz Gładysz, lek.`}
  description={article.seoDescription || article.excerpt}
  locale="pl"
  alternateUrl={alternateUrl}
  canonical={canonicalUrl}
  jsonLd={[articleJsonLd, breadcrumbJsonLd]}
>
  <article class="article-shell">
    <header class="article-header">
      <p class="article-kicker">
        <a href="/pl/blog/">Baza wiedzy</a>
        <span aria-hidden="true">·</span>
        <span>{categoryLabel[article.category] ?? article.category}</span>
      </p>
      <h1 class="article-title">{article.title}</h1>
      {authorByline && <p class="article-byline">{authorByline}</p>}
      {standfirstText && <p class="article-standfirst">{standfirstText}</p>}
      <p class="article-meta">
        <span>
          Opublikowano <time datetime={article.publishedDate}>{publishedDateLabel}</time>
        </span>
        {updatedDateLabel && (
          <>
            <span aria-hidden="true">·</span>
            <span>
              Ostatnia weryfikacja medyczna <time datetime={article.lastUpdated}>{updatedDateLabel}</time>
            </span>
          </>
        )}
      </p>
    </header>

    {heroImageUrl && (
      <figure class="article-hero">
        <img
          src={heroImageUrl}
          alt={article.heroImage?.alt ?? ''}
          loading="eager"
          decoding="async"
        />
      </figure>
    )}

    <div class="article-content">
      {article.keyPoints && (
        <KeyPoints
          question={article.keyPoints.question}
          findings={article.keyPoints.findings}
          meaning={article.keyPoints.meaning}
        />
      )}

      <div class="article-body">
        <PortableTextRenderer
          value={article.body}
          references={references}
          glossaryTerms={glossaryTerms}
        />
      </div>

      <Bibliography references={references} />

      {hasRelated && (
        <aside class="article-related" aria-labelledby="related-heading">
          <h2 id="related-heading" class="related-heading">Powiązane</h2>
          {relatedArticles.length > 0 && (
            <section class="related-section">
              <p class="related-kicker">Artykuły</p>
              <ul class="related-list">
                {relatedArticles.map((a) => (
                  <li>
                    <a href={`/pl/blog/${a.slug.current}/`}>
                      <span class="related-title">{a.title}</span>
                      <span class="related-meta">{articleCategoryLabel[a.category] ?? a.category}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          )}
          {relatedProcedures.length > 0 && (
            <section class="related-section">
              <p class="related-kicker">Zabiegi</p>
              <ul class="related-list">
                {relatedProcedures.map((p) => (
                  <li>
                    <a href={`/pl/zabiegi/${p.slug.current}/`}>
                      <span class="related-title">{p.title}</span>
                      <span class="related-meta">{procedureCategoryLabel[p.category] ?? p.category}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          )}
        </aside>
      )}
    </div>
  </article>
</SiteLayout>

<style>
  .article-shell {
    max-width: 1320px;
    margin: 0 auto;
    padding: clamp(40px, 7vw, 96px) clamp(20px, 5vw, 80px) 120px;
  }

  .article-header {
    margin-bottom: clamp(40px, 6vw, 80px);
    max-width: 760px;
  }

  .article-kicker {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin: 0 0 24px;
    display: flex;
    gap: 12px;
    align-items: center;
  }

  .article-kicker a {
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid var(--accent);
    padding-bottom: 1px;
  }

  .article-kicker a:hover {
    color: var(--ink);
    border-bottom-color: var(--ink);
  }

  .article-title {
    font-family: var(--serif);
    font-weight: 500;
    font-size: clamp(34px, 5vw, 56px);
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--ink);
    margin: 0 0 16px;
  }

  .article-byline {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 24px;
  }

  .article-standfirst {
    font-family: var(--serif);
    font-style: italic;
    font-size: clamp(18px, 1.6vw, 22px);
    line-height: 1.55;
    color: var(--ink-2);
    margin: 0 0 28px;
    max-width: 60ch;
  }

  .article-meta {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.06em;
    color: var(--ink-3);
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin: 0;
  }

  .article-hero {
    margin: 0 0 64px;
  }

  .article-hero img {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 16/9;
    object-fit: cover;
  }

  .article-content {
    max-width: 720px;
    margin: 0;
    position: relative;
  }

  @media (min-width: 1024px) {
    .article-content {
      padding-right: 320px;
      max-width: 1040px;
    }
  }

  .article-body::after {
    content: '';
    display: block;
    clear: both;
  }

  .article-related {
    margin-top: clamp(48px, 6vw, 80px);
    padding-top: 32px;
    border-top: 1px solid var(--ink-3);
  }

  .related-heading {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin: 0 0 24px;
  }

  .related-section { margin-bottom: 24px; }
  .related-section:last-child { margin-bottom: 0; }

  .related-kicker {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: var(--accent);
    margin: 0 0 12px;
  }

  .related-list { list-style: none; margin: 0; padding: 0; }

  .related-list li {
    margin: 0;
    padding: 0;
    border-top: 1px solid color-mix(in oklab, var(--ink-3) 30%, transparent);
  }

  .related-list li:last-child {
    border-bottom: 1px solid color-mix(in oklab, var(--ink-3) 30%, transparent);
  }

  .related-list a {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 16px;
    padding: 14px 0;
    text-decoration: none;
    color: var(--ink);
  }

  .related-list a:hover .related-title { color: var(--accent); }

  .related-title {
    font-family: var(--serif);
    font-size: 18px;
    line-height: 1.35;
  }

  .related-meta {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-3);
    flex-shrink: 0;
  }
</style>
