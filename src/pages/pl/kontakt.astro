---
// src/pages/pl/kontakt.astro
//
// Polish Contact page (Strona Kontakt). Locked content from
// 01-brand-system/polish content/drgladysz-content-pl-master-v0_3.md
// Sekcje 1–5. Independent Polish composition per Decision #13.
//
// Decision #59 (Wariant A): "Dla pacjentów" handles three scenarios in
// three paragraphs — (1) NZ patients (incl. Polish-speaking residents)
// → GP referral; (2) acute injuries → ED; (3) patients outside NZ
// → honest information that the site does not serve them. PL deliberately
// diverges from the EN draft's "patient enquiries from outside NZ via form"
// routing, which would have been misleading.
//
// Decision #62: full Polish RODO regulation name at first occurrence,
// skrót RODO in parentheses; Privacy Act 2020 retained in original.
//
// API endpoint /api/contact is locale-agnostic; form posts identical
// payload shape to EN. Internal enum values preserved for API back-compat
// (professional / clinical / editorial / other) — only the user-facing
// labels are localised.
import SiteLayout from '@/layouts/SiteLayout.astro';
import ContentPage from '@/components/ContentPage.astro';
import SectionMasthead from '@/components/SectionMasthead.astro';
import { generateContactPageSchema } from '@/lib/schema';

const siteUrl = (
  import.meta.env.PUBLIC_SITE_URL || 'https://drgladysz.com'
).replace(/\/$/, '');
const canonicalUrl = `${siteUrl}/pl/kontakt/`;

const contactPageJsonLd = generateContactPageSchema({
  url: canonicalUrl,
  locale: 'pl',
  siteUrl,
  name: 'Kontakt — Mateusz Gładysz',
});
---
<SiteLayout
  title="Kontakt — Mateusz Gładysz, lek."
  description="Formy kontaktu i ścieżki skierowań w Nowej Zelandii. Korespondencja zawodowa, akademicka i medialna przez formularz lub office@drgladysz.com."
  locale="pl"
  alternateUrl="/en/contact/"
  canonical={canonicalUrl}
  jsonLd={contactPageJsonLd}
>
  <ContentPage
    label="Kontakt"
    title="Kontakt"
    standfirst="Niniejsza strona przedstawia formy kontaktu dla pacjentów oraz w korespondencji zawodowej i akademickiej. Zasady prowadzenia praktyki oraz ścieżki skierowań opisano w sekcjach poniżej."
  >
    <section class="contact-section">
      <header class="contact-section-header">
        <div class="section-num">§ 01</div>
        <SectionMasthead label="Praktyka" heading="Obecna praktyka" />
      </header>
      <p>
        Obecna praktyka kliniczna prowadzona jest w Waikato Hospital w Hamilton, w Nowej Zelandii. Zakres pracy obejmuje chirurgię ręki, mikrochirurgię rekonstrukcyjną oraz chirurgiczne leczenie czerniaka i zaawansowanych nowotworów skóry w ramach wielospecjalistycznego zespołu ds. czerniaka i nowotworów skóry wysokiego ryzyka.
      </p>
      <p>
        Opieka nad pacjentami w nowozelandzkim systemie publicznym opiera się na skierowaniach. Wizyty nowych pacjentów organizowane są przez regionalną poradnię po skierowaniu od lekarza pierwszego kontaktu (<em>General Practitioner</em>, GP), nie bezpośrednio przez tę stronę.
      </p>
    </section>

    <section class="contact-section">
      <header class="contact-section-header">
        <div class="section-num">§ 02</div>
        <SectionMasthead label="Skierowania" heading="Dla pacjentów" />
      </header>
      <p>
        Pacjenci w Nowej Zelandii — w tym osoby polskojęzyczne mieszkające na stałe w tym kraju — uzyskują dostęp do leczenia w zakresie chirurgii ręki, rekonstrukcji tkanek miękkich oraz chirurgii nowotworów skóry przez skierowanie od lekarza pierwszego kontaktu (GP). Lekarz rodzinny kieruje pacjenta do regionalnej poradni chirurgii ręki i chirurgii plastycznej, gdzie skierowania podlegają triażowi, a wizyty są organizowane w ramach systemu publicznego.
      </p>
      <p>
        W przypadku ostrych urazów ręki — w tym podejrzenia złamania kości łódeczkowatej, urazów ścięgien lub ran z uszkodzeniem struktur głębokich — właściwą drogą jest miejscowy szpitalny oddział ratunkowy, który w razie wskazań organizuje konsultację zespołu chirurgii ręki. Pilne sytuacje wymagają drogi innej niż ta strona. W razie zagrożenia życia w Nowej Zelandii należy zadzwonić pod numer <strong>111</strong>; w Polsce i Unii Europejskiej pod numer <strong>112</strong>.
      </p>
      <p>
        Praktyka kliniczna prowadzona jest obecnie w Nowej Zelandii. Strona nie służy do umawiania konsultacji ani udzielania porad medycznych pacjentom mieszkającym poza Nową Zelandią.
      </p>
    </section>

    <section class="contact-section">
      <header class="contact-section-header">
        <div class="section-num">§ 03</div>
        <SectionMasthead label="Zapytania" heading="Zapytania zawodowe i akademickie" />
      </header>
      <p>
        Korespondencję od lekarzy, naukowców, redaktorów czasopism, organizatorów konferencji oraz współpracowników akademickich obsługuje formularz poniżej lub adres <a class="contact-email" href="mailto:office@drgladysz.com">office@drgladysz.com</a>. Tym samym kanałem prowadzona jest korespondencja w sprawie zaproszeń do wystąpień, wykładów, podcastów oraz innych form udziału w wydarzeniach zawodowych i edukacyjnych.
      </p>
    </section>

    <section class="contact-section" id="form">
      <header class="contact-section-header">
        <div class="section-num">§ 04</div>
        <SectionMasthead label="Formularz" heading="Wyślij zapytanie" />
      </header>

      <form
        action="/api/contact"
        method="post"
        class="contact-form"
        data-contact-form
        novalidate
      >
        <div class="hp-field" aria-hidden="true">
          <label for="contact-website">Website (leave empty)</label>
          <input
            id="contact-website"
            name="website"
            type="text"
            tabindex="-1"
            autocomplete="off"
          />
        </div>
        <div class="field">
          <label for="contact-name">Imię i nazwisko</label>
          <input
            id="contact-name"
            name="Name"
            type="text"
            maxlength="120"
            autocomplete="name"
            required
            aria-required="true"
          />
        </div>
        <div class="field">
          <label for="contact-from">Adres email</label>
          <input
            id="contact-from"
            name="Email"
            type="email"
            autocomplete="email"
            required
            aria-required="true"
          />
        </div>
        <div class="field">
          <label for="contact-context">Rodzaj zapytania</label>
          <select id="contact-context" name="Context" required aria-required="true">
            <option value="">Wybierz…</option>
            <option value="professional">Zapytanie zawodowe lub akademickie</option>
            <option value="clinical">Informacje dla pacjenta</option>
            <option value="editorial">Media lub wystąpienie publiczne</option>
            <option value="other">Inne</option>
          </select>
        </div>
        <div class="field">
          <label for="contact-subject">Temat</label>
          <input
            id="contact-subject"
            name="Subject"
            type="text"
            maxlength="160"
            required
            aria-required="true"
          />
        </div>
        <div class="field">
          <label for="contact-message">Wiadomość</label>
          <textarea
            id="contact-message"
            name="Message"
            rows="8"
            maxlength="4000"
            required
            aria-required="true"
          ></textarea>
        </div>
        <div class="field field-checkbox">
          <input
            id="contact-consent"
            name="Consent"
            type="checkbox"
            required
            aria-required="true"
          />
          <label for="contact-consent">
            Wyrażam zgodę na przetwarzanie danych osobowych przesłanych w formularzu w celu udzielenia odpowiedzi na zapytanie. Potwierdzam zapoznanie się z <a href="/pl/polityka-prywatnosci/">Polityką prywatności</a>.
          </label>
        </div>
        <button type="submit" class="contact-submit">
          Wyślij zapytanie <span class="cta-arrow" aria-hidden="true">&rarr;</span>
        </button>
        <p class="form-status" data-contact-status role="status" aria-live="polite"></p>
        <p class="form-note">
          Formularz przesyła korespondencję na adres <a href="mailto:office@drgladysz.com">office@drgladysz.com</a>. Odpowiedzi wysyłane są z tego samego adresu. Konkretne porady kliniczne nie są udzielane drogą mailową.
        </p>
      </form>
      <script is:inline>
        (() => {
          const form = document.querySelector('[data-contact-form]');
          if (!form) return;
          const status = form.querySelector('[data-contact-status]');
          const submit = form.querySelector('button[type="submit"]');
          const ERRORS = {
            invalid_name: 'Proszę podać imię i nazwisko.',
            invalid_email: 'Proszę podać prawidłowy adres email.',
            invalid_context: 'Proszę wybrać rodzaj zapytania.',
            invalid_subject: 'Proszę podać temat (do 160 znaków).',
            invalid_message: 'Proszę napisać wiadomość (co najmniej 10 znaków).',
            invalid_consent: 'Proszę potwierdzić zgodę, aby przesłać formularz.',
            rate_limited: 'Zbyt wiele zgłoszeń z tego adresu w ostatnim czasie. Proszę spróbować ponownie za kilka minut.',
            send_failed: 'Wiadomości nie udało się wysłać. Proszę spróbować ponownie lub napisać bezpośrednio na adres office@drgladysz.com.',
            server_misconfigured: 'Formularz jest chwilowo niedostępny. Proszę napisać bezpośrednio na adres office@drgladysz.com.',
          };
          form.addEventListener('submit', async (event) => {
            event.preventDefault();
            submit.disabled = true;
            status.textContent = 'Wysyłanie…';
            status.className = 'form-status';
            try {
              const response = await fetch('/api/contact', {
                method: 'POST',
                body: new FormData(form),
              });
              const result = await response.json();
              if (result.ok) {
                status.textContent = 'Wiadomość została wysłana. Odpowiedź zostanie przesłana na podany adres.';
                status.className = 'form-status is-success';
                form.reset();
              } else {
                status.textContent = ERRORS[result.error] || 'Coś poszło nie tak. Proszę spróbować ponownie lub napisać bezpośrednio na adres office@drgladysz.com.';
                status.className = 'form-status is-error';
              }
            } catch {
              status.textContent = 'Błąd sieci. Proszę spróbować ponownie lub napisać bezpośrednio na adres office@drgladysz.com.';
              status.className = 'form-status is-error';
            } finally {
              submit.disabled = false;
            }
          });
        })();
      </script>
    </section>

    <section class="contact-section">
      <header class="contact-section-header">
        <div class="section-num">§ 05</div>
        <SectionMasthead label="Prywatność" heading="Sposób przetwarzania danych z formularza" />
      </header>
      <p>
        Dane przesłane przez formularz przetwarzane są wyłącznie w celu udzielenia odpowiedzi na zapytanie. Administratorem danych jest Mateusz Gładysz. Podstawą przetwarzania jest zgoda na podstawie art. 6 ust. 1 lit. a) Rozporządzenia Parlamentu Europejskiego i Rady (UE) 2016/679 (RODO) w odniesieniu do osób przebywających w Unii Europejskiej oraz uzasadniony cel prowadzenia korespondencji na podstawie nowozelandzkiej ustawy Privacy Act 2020 w odniesieniu do osób przebywających w Nowej Zelandii. Zgłoszenia przechowywane są przez okres prowadzenia korespondencji oraz przez rozsądny czas po jej zakończeniu. Pełna <a href="/pl/polityka-prywatnosci/">Polityka prywatności</a> opisuje prawa osób, których dane dotyczą, oraz sposób ich realizacji.
      </p>
    </section>
  </ContentPage>
</SiteLayout>

<style>
  /* Section layout — same scaffold as /en/contact (§-number prefix in
     mono caps + accent top rule, SectionMasthead beneath, body content
     follows). Visual parity is intentional — only the prose differs. */
  .contact-section {
    margin-bottom: clamp(48px, 7vw, 88px);
  }
  .contact-section:last-child {
    margin-bottom: 0;
  }

  .contact-section-header {
    margin-bottom: 28px;
  }

  .section-num {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.10em;
    color: var(--accent);
    padding-top: 10px;
    border-top: 2px solid var(--accent);
    margin-bottom: 16px;
    width: fit-content;
    min-width: 48px;
  }

  .contact-email {
    font-family: var(--mono);
    font-size: 0.92em;
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid var(--accent);
    padding-bottom: 1px;
    transition: color 0.15s ease, border-color 0.15s ease;
  }
  .contact-email:hover,
  .contact-email:focus-visible {
    color: var(--ink);
    border-bottom-color: var(--ink);
  }

  .contact-form {
    display: grid;
    gap: 20px;
    margin: 0;
    max-width: 560px;
  }

  .field {
    display: grid;
    gap: 6px;
  }

  .field > label {
    font-family: var(--mono);
    font-size: 12px;
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: var(--ink-3);
  }

  .field input[type="text"],
  .field input[type="email"],
  .field select,
  .field textarea {
    font-family: var(--sans);
    font-size: 16px;
    line-height: 1.5;
    color: var(--ink);
    background: var(--bg-card);
    border: 1px solid var(--rule-strong);
    border-radius: 0;
    padding: 10px 12px;
    width: 100%;
  }

  .field input:focus,
  .field select:focus,
  .field textarea:focus {
    outline: 2px solid var(--accent);
    outline-offset: 0;
    border-color: var(--accent);
  }

  .field textarea {
    resize: vertical;
    min-height: 160px;
    font-family: var(--serif);
    font-size: 17px;
    line-height: 1.55;
  }

  .field-checkbox {
    grid-template-columns: auto 1fr;
    align-items: start;
    gap: 12px;
    margin-top: 4px;
  }
  .field-checkbox > input[type="checkbox"] {
    width: 18px;
    height: 18px;
    margin: 3px 0 0;
    accent-color: var(--accent);
  }
  .field-checkbox > input[type="checkbox"]:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .field-checkbox > label {
    font-family: var(--sans);
    font-size: 14px;
    line-height: 1.5;
    color: var(--ink-2);
    text-transform: none;
    letter-spacing: 0;
  }
  .field-checkbox > label a {
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid var(--accent);
    padding-bottom: 1px;
  }
  .field-checkbox > label a:hover {
    color: var(--ink);
    border-bottom-color: var(--ink);
  }

  .contact-submit {
    justify-self: start;
    font-family: var(--sans);
    font-weight: 500;
    font-size: 15px;
    letter-spacing: 0.02em;
    color: var(--bg);
    background: var(--ink);
    border: 0;
    padding: 14px 28px;
    cursor: pointer;
    border-radius: 0;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    transition: background 0.2s ease;
  }

  .contact-submit:hover,
  .contact-submit:focus-visible {
    background: var(--accent);
  }

  .contact-submit:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 4px;
  }

  .contact-submit[disabled] {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .cta-arrow {
    font-family: var(--mono);
    font-size: 16px;
  }

  .form-note {
    font-family: var(--sans);
    font-size: 14px;
    line-height: 1.55;
    color: var(--ink-3);
    margin: 8px 0 0;
    max-width: 56ch;
  }
  .form-note a {
    color: inherit;
    border-bottom: 1px solid var(--rule-strong);
  }

  .hp-field {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .form-status {
    font-family: var(--sans);
    font-size: 14px;
    line-height: 1.55;
    color: var(--ink-2);
    margin: 0;
    min-height: 1.55em;
  }
  .form-status.is-success { color: var(--accent); font-weight: 500; }
  .form-status.is-error { color: var(--ink); font-weight: 600; }
</style>
