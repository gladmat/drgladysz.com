---
// src/layouts/BaseLayout.astro
import '@/styles/globals.css';
import { getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { IMAGE_WIDTHS, IMAGE_QUALITY, IMAGE_SIZES_FULLBLEED } from '@/lib/image-config';

interface HeroPreload {
  src: ImageMetadata;
  sizes?: string;
  widths?: number[];
}

interface Props {
  title: string;
  description?: string;
  locale?: 'en' | 'pl';
  alternateUrl?: string;
  canonical?: string;
  ogImage?: string;
  jsonLd?: Record<string, any> | Record<string, any>[];
  // Preloads the AVIF variant of the LCP image with <link rel="preload">.
  // Browsers that don't support AVIF skip the preload and fetch via <picture>.
  heroPreload?: HeroPreload;
}

const {
  title,
  description = 'Mateusz Gładysz, MD, FEBOPRAS, FEBHS — Consultant Plastic and Hand Surgeon',
  locale = 'en',
  alternateUrl,
  canonical,
  ogImage = '/og/default.jpg',
  jsonLd,
  heroPreload,
} = Astro.props;

const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://drgladysz.com';
const fullTitle = title.includes('Mateusz') ? title : `${title} — Mateusz Gładysz, MD`;
const canonicalUrl = canonical || `${siteUrl}${Astro.url.pathname}`;
const langCode = locale === 'pl' ? 'pl-PL' : 'en-NZ';
const altLangCode = locale === 'pl' ? 'en-NZ' : 'pl-PL';

// Compute the AVIF srcset for the LCP hero so the browser starts fetching
// before HTML body parsing. The options here MUST match PhotoBreak's <Picture>
// exactly (widths, quality) — otherwise the preloaded URL hashes differ from
// what <picture> resolves and the browser fetches twice.
let heroPreloadAttrs: { srcset: string; sizes: string } | null = null;
if (heroPreload) {
  const optimized = await getImage({
    src: heroPreload.src,
    format: 'avif',
    widths: heroPreload.widths ?? [...IMAGE_WIDTHS],
    quality: IMAGE_QUALITY,
  });
  heroPreloadAttrs = {
    srcset: optimized.srcSet.attribute,
    sizes: heroPreload.sizes ?? IMAGE_SIZES_FULLBLEED,
  };
}
---

<!DOCTYPE html>
<html lang={locale}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />
  
  <!-- Primary meta -->
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  
  <!-- Hreflang -->
  <link rel="alternate" hreflang={langCode} href={canonicalUrl} />
  {alternateUrl && (
    <link rel="alternate" hreflang={altLangCode} href={`${siteUrl}${alternateUrl}`} />
  )}
  <link rel="alternate" hreflang="x-default" href={`${siteUrl}/en/`} />
  
  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:image" content={`${siteUrl}${ogImage}`} />
  <meta property="og:locale" content={langCode.replace('-', '_')} />
  
  <!-- Twitter card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />
  
  <!-- Favicon — MG monogram per brand spec v1.7 §2.
       SVG is the canonical mark; PNGs cover Android home-screen + iOS Safari
       add-to-home-screen, which still want raster assets. -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png" />
  <link rel="icon" type="image/png" sizes="512x512" href="/favicon-512.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
  
  <!-- Preload critical fonts -->
  <link rel="preload" href="/fonts/IBMPlexSerif-Medium.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/IBMPlexSans-Regular.woff2" as="font" type="font/woff2" crossorigin />

  <!-- LCP hero preload (AVIF) -->
  {heroPreloadAttrs && (
    <link
      rel="preload"
      as="image"
      type="image/avif"
      imagesrcset={heroPreloadAttrs.srcset}
      imagesizes={heroPreloadAttrs.sizes}
      fetchpriority="high"
    />
  )}
  
  <!-- Schema.org JSON-LD -->
  {jsonLd && (
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  )}
  
  <!-- Plausible analytics (cookie-free, EU-hosted) -->
  <script
    defer
    data-domain={import.meta.env.PUBLIC_PLAUSIBLE_DOMAIN || 'drgladysz.com'}
    src="https://plausible.io/js/script.js"
  ></script>
</head>
<body>
  <a href="#main" class="skip-to-main">Skip to main content</a>
  
  <slot name="header" />
  
  <main id="main">
    <slot />
  </main>
  
  <slot name="footer" />
  
  <style>
    .skip-to-main {
      position: absolute;
      left: -9999px;
      top: 0;
      background: var(--ink);
      color: var(--bg);
      padding: 12px 24px;
      z-index: 100;
      text-decoration: none;
      font-family: var(--sans);
      font-size: 14px;
    }
    
    .skip-to-main:focus {
      left: 0;
      outline: 2px solid var(--accent);
    }
  </style>
</body>
</html>
